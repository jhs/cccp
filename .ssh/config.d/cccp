# Aliases for CCCP transport. It passes
# hostnames verbatim to SSH; these aliases give bare comrade-host
# labels a real address. Tailscale's bare-hostname convention collides
# with traditional LAN name resolution, so explicit aliases avoid
# surprises across accounts that may or may not have MagicDNS.

Host host-b
  HostName host-b.example

Host host-a
  HostName host-a.example

Host staging-hub
  HostName hub.example.com
  User azureuser
