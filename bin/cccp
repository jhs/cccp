#!/usr/bin/env python3
"""cccp - Claude-to-Claude Communication Protocol (v2 - Azure Blob transport).

v2 replaces the v1 SSH/rsync mesh with a single Azure Blob Storage container as
a shared rendezvous: every comrade reads and writes one container, and there are
no peer-to-peer connections. Transport is pure Python stdlib (urllib) against the
Blob REST API, authenticated by a container-scoped SAS token - no SDK, no binary,
so it runs anywhere Python 3 does.

Storage layout (a cell is the triple (account, container, prefix) + slug):

    <container>/<prefix>/<slug>/<comrade-id>/gazette.jsonl   append blob
    <container>/<prefix>/<slug>/<comrade-id>/files/<path>    block blobs
    <container>/<prefix>/<slug>/<comrade-id>/claim           identity claim
    <container>/<prefix>/<slug>/<comrade-id>/gone.json       explicit leave

bin/cccp is an executable script, not an importable module. When an ad-hoc
one-off needs the REST logic (e.g. the large-file staging fallback), read this
file as a reference implementation rather than importing it.

Subcommands (build in progress):
    init        Resolve identity + roster for a cell (SKILL.md render-time helper).
    dispatch    Send a message to a cell.
    watchtower  Stream live cell events (run under the Monitor tool).
    leave       Leave a cell (writes gone.json).
    read        Print cell message history.
    rm          Delete a cell and all its blobs (user-directed).
    publish     Share a file with a cell.
    unpublish   Withdraw a previously-published file.
    pull        Download published files into the local mirror.
"""

import argparse
import json
import os
import pwd
import re
import signal
import socket
import subprocess
import sys
import threading
import time
import urllib.error
import urllib.parse
import urllib.request
import xml.etree.ElementTree as ET
from datetime import datetime, timezone
from pathlib import Path

API_VERSION = "2023-11-03"
DEFAULT_PREFIX = "__default__"
CONFIG_PATH = Path.home() / ".config" / "cccp" / "config"
POLL_LADDER = (            # seconds; the adaptive inter-poll gap. First entry is
    2, 5, 15, 30, 60,      # the "fast" cadence used right after activity; each
    120, 180, 300,         # no-activity poll advances one rung. Last entry is
)                          # the cap (5min), stays there indefinitely while
                           # idle. Any real event resets back to entry 0;
                           # SIGUSR1 (cccp wake) does the same plus polls
                           # immediately. 2s floor because polling is a network
                           # LIST against Azure Blob and a comrade takes
                           # multiple seconds just to emit a message anyway.
TRUNCATE_THRESHOLD = 480   # render a header-only event above this many chars
PREVIEW_BUDGET = 150       # preview chars carried on a truncated event
IDLE_MAX_SECONDS = 24 * 3600   # cap for the idle backoff - past this, idles fire
                               # at most once a day so a long-silent watchtower
                               # stops forcing Claude to wake and respond
PUBLISH_MAX = 256 * 1024 * 1024   # single-PUT publish ceiling; larger needs staging
AUTODOWNLOAD_MAX = 1024 * 1024    # watchtower auto-downloads published files at or
                                  # under this size; larger ones are only announced
                                  # (Claude fetches them with `cccp pull`). Bounded
                                  # by what downloads fast enough not to stall the
                                  # poll loop - not by "how big a file is".
LOCAL_MIRROR = Path.home() / ".cccp"   # where pulled / auto-downloaded files land
TEXT_EXTENSIONS = {
    ".txt", ".md", ".rst", ".html", ".htm", ".xml", ".csv", ".tsv", ".json",
    ".yaml", ".yml", ".toml", ".ini", ".cfg", ".conf", ".log", ".sh", ".bash",
    ".zsh", ".py", ".js", ".ts", ".jsx", ".tsx", ".c", ".h", ".cpp", ".hpp",
    ".cc", ".go", ".rs", ".java", ".rb", ".pl", ".php", ".lua", ".sql", ".css",
    ".scss", ".vue", ".svelte", ".tf", ".hcl", ".env", ".gitignore",
}


# ---------- identity & misc helpers ----------

def now_iso():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%fZ")


def current_user():
    return pwd.getpwuid(os.getuid()).pw_name


def short_hostname():
    return socket.gethostname().split(".")[0]


def base_comrade_id():
    """The clean, cell-scoped-unique-by-default comrade id: user@host."""
    return f"{current_user()}@{short_hostname()}"


def slugify(name):
    s = re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")
    if not s:
        raise ValueError(f"Cell name {name!r} produced an empty slug")
    return s


def current_session_id():
    """The Claude Code session UUID, exported as CLAUDE_CODE_SESSION_ID.

    Stable for the whole conversation, including across `claude --resume`. Every
    cccp invocation from one Claude session reads the same value, so identity
    stays consistent across the separate init / dispatch / watchtower processes
    with no local state file. Used as the cross-invocation re-derivation key
    and (truncated to 6 chars) as the same-host collision disambiguator; the
    default comrade id stays the clean user@host.

    Non-Claude callers (manual testing, scripts) should set CCCP_COMRADE_ID to
    bypass identity claim entirely.
    """
    sid = os.environ.get("CLAUDE_CODE_SESSION_ID")
    if not sid:
        sys.exit("error: CLAUDE_CODE_SESSION_ID is not set; cccp must run under "
                 "Claude Code, or set CCCP_COMRADE_ID to bypass identity claim")
    return sid


# ---------- config resolution ----------

def _parse_cccp_env(path):
    """Parse a KEY=value file, returning only its CCCP_* keys."""
    cfg = {}
    for line in Path(path).read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("CCCP_"):
            cfg[k] = v.strip()
    return cfg


def resolve_config(start=None):
    """Resolve the CCCP storage config for the current working directory.

    Walk up from CWD for the closest `.env` that carries CCCP_* keys - that one
    wins entirely (per-project override). Otherwise fall back to the personal
    default at ~/.config/cccp/config. CCCP_PREFIX is optional and defaults to
    __default__, so a config only needs ACCOUNT, CONTAINER, and SAS.

    Returns a dict with ACCOUNT, CONTAINER, SAS, PREFIX.
    """
    start = Path(start or os.getcwd()).resolve()
    found = None
    for d in (start, *start.parents):
        env = d / ".env"
        if env.is_file():
            cfg = _parse_cccp_env(env)
            if cfg:  # only counts as a CCCP config if it has CCCP_* keys
                found = cfg
                break
    if found is None:
        if not CONFIG_PATH.is_file():
            sys.exit(f"error: no CCCP config - no .env with CCCP_* keys at or "
                     f"above {start}, and {CONFIG_PATH} is missing "
                     f"(run tf/apply.sh, then install.sh)")
        found = _parse_cccp_env(CONFIG_PATH)

    out = {
        "ACCOUNT": found.get("CCCP_ACCOUNT"),
        "CONTAINER": found.get("CCCP_CONTAINER"),
        "SAS": (found.get("CCCP_SAS") or "").lstrip("?"),
        "PREFIX": found.get("CCCP_PREFIX") or DEFAULT_PREFIX,
    }
    missing = [k for k in ("ACCOUNT", "CONTAINER", "SAS") if not out[k]]
    if missing:
        sys.exit(f"error: CCCP config is missing keys: {missing}")
    return out


# ---------- Azure Blob REST client ----------

class BlobError(Exception):
    def __init__(self, status, body):
        self.status = status
        self.body = body
        super().__init__(f"blob error {status}: {body[:200]!r}")


class BlobClient:
    """Minimal Azure Blob REST client - stdlib urllib plus a container SAS.

    Paths are relative to the container; the SAS supplies all authentication.
    """

    RETRYABLE = (500, 502, 503, 504)

    def __init__(self, account, container, sas):
        self.base = f"https://{account}.blob.core.windows.net/{container}"
        self.sas = sas.lstrip("?")

    def _url(self, path, query=""):
        u = f"{self.base}/{path}" if path else self.base
        return u + "?" + "&".join(p for p in (query, self.sas) if p)

    def request(self, method, path, query="", data=None, headers=None, retries=3):
        """One REST call. Returns (status, headers_dict, body_bytes).

        Transient 5xx are retried with a short backoff. An HTTPError (4xx) is
        returned, not raised, so callers can branch on expected statuses such as
        the 409 from a conditional create or a 416 past end-of-blob.
        """
        h = {"x-ms-version": API_VERSION}
        if headers:
            h.update(headers)
        url = self._url(path, query)
        for attempt in range(retries):
            req = urllib.request.Request(url, data=data, method=method, headers=h)
            try:
                resp = urllib.request.urlopen(req, timeout=30)
                return resp.status, dict(resp.headers), resp.read()
            except urllib.error.HTTPError as e:
                if e.code in self.RETRYABLE and attempt < retries - 1:
                    time.sleep(0.5 * (attempt + 1))
                    continue
                return e.code, dict(e.headers), e.read()
            except urllib.error.URLError:
                if attempt < retries - 1:
                    time.sleep(0.5 * (attempt + 1))
                    continue
                raise

    # -- convenience operations --

    def put_block(self, path, data, if_none_match=False):
        """PUT a block blob. With if_none_match, creates only if absent (201) and
        returns 409 if it already exists."""
        h = {"x-ms-blob-type": "BlockBlob"}
        if if_none_match:
            h["If-None-Match"] = "*"
        return self.request("PUT", path, data=data, headers=h)[0]

    def get(self, path):
        st, _, body = self.request("GET", path)
        return st, body

    def get_range(self, path, offset):
        """GET a blob from byte `offset` to the end. Returns (status, body)."""
        st, _, body = self.request("GET", path, headers={"Range": f"bytes={offset}-"})
        return st, body

    def ensure_append_blob(self, path):
        """Create an append blob if absent. 201 created or 409 exists - both fine."""
        return self.request("PUT", path, data=b"",
                            headers={"x-ms-blob-type": "AppendBlob",
                                     "If-None-Match": "*"})[0]

    def append_block(self, path, data):
        """Append bytes to the end of an append blob."""
        return self.request("PUT", path, query="comp=appendblock", data=data)[0]

    def list(self, prefix):
        """List blobs under a prefix. Returns {name: {"size", "last_modified"}}."""
        st, _, body = self.request(
            "GET", "",
            query=f"restype=container&comp=list&prefix={urllib.parse.quote(prefix)}")
        if st != 200:
            raise BlobError(st, body)
        root = ET.fromstring(body)
        out = {}
        for b in root.findall(".//Blob"):
            name = b.findtext("Name")
            props = b.find("Properties")
            size = props.findtext("Content-Length") if props is not None else None
            lm = props.findtext("Last-Modified") if props is not None else None
            out[name] = {"size": int(size) if size else 0, "last_modified": lm}
        return out


# ---------- identity claim & roster ----------

def claim_identity(client, prefix, slug):
    """Resolve (claiming if needed) this session's comrade id for a cell.

    Idempotent and self-recomputing: every cccp invocation from the same Claude
    session arrives at the same id, keyed on the Claude session UUID. The clean
    `user@host` is used by default; a sibling session on the same host that
    finds it already taken falls back to `user@host:<first-6-of-session-id>`.

    CCCP_COMRADE_ID in the environment overrides all of this with an explicit id
    (used for testing and deliberate identity control).
    """
    env_id = os.environ.get("CCCP_COMRADE_ID")
    if env_id:
        client.put_block(f"{prefix}/{slug}/{env_id}/claim",
                         json.dumps({"ts": now_iso()}).encode())
        return env_id
    base = base_comrade_id()
    mysession = current_session_id()
    body = json.dumps({"session_id": mysession, "ts": now_iso()}).encode()
    base_claim = f"{prefix}/{slug}/{base}/claim"

    st = client.put_block(base_claim, body, if_none_match=True)
    if st == 201:
        return base                       # claimed the clean id
    if st == 409:
        # Someone holds the clean id - a prior invocation of mine, or a sibling?
        gst, gbody = client.get(base_claim)
        owner_session = None
        if gst == 200:
            try:
                owner_session = json.loads(gbody).get("session_id")
            except (ValueError, AttributeError):
                pass
        if owner_session == mysession:
            return base                   # it is mine - a re-run from this session
        suffix_id = f"{base}:{mysession[:6]}"
        client.put_block(f"{prefix}/{slug}/{suffix_id}/claim", body)  # overwrite ok
        return suffix_id
    raise BlobError(st, b"")


def cell_roster(client, prefix, slug):
    """Return the sorted comrade ids registered in a cell."""
    head = f"{prefix}/{slug}/"
    comrades = set()
    for name in client.list(head):
        rest = name[len(head):]
        if "/" in rest:
            comrades.add(rest.split("/", 1)[0])
    return sorted(comrades)


# ---------- gazette ----------

def gazette_path(prefix, slug, comrade):
    return f"{prefix}/{slug}/{comrade}/gazette.jsonl"


def append_dispatch(client, prefix, slug, me, dispatch):
    """Append one dispatch (a JSON object) as a line to my gazette append blob."""
    path = gazette_path(prefix, slug, me)
    client.ensure_append_blob(path)
    line = (json.dumps(dispatch, separators=(",", ":")) + "\n").encode("utf-8")
    st = client.append_block(path, line)
    if st != 201:
        raise BlobError(st, b"gazette append failed")


# ---------- event rendering ----------

def display_path(wire_path):
    """Recover the publisher's original absolute path from the wire path."""
    if wire_path.startswith("files/"):
        return "/" + wire_path[len("files/"):]
    return wire_path


def render_to(to):
    return "*" if to == ["*"] else ",".join(to)


def addressed_to_me(to, me):
    return "*" in to or me in to


def safe_preview_inner(body, max_inner_chars=PREVIEW_BUDGET):
    """JSON-inner (no surrounding quotes) of a body prefix that fits the preview
    budget after JSON-escaping, without splitting an escape sequence."""
    n, inner = 0, ""
    while n < len(body):
        candidate = json.dumps(body[:n + 1])[1:-1]
        if len(candidate) > max_inner_chars:
            break
        inner = candidate
        n += 1
    return inner


def render_message_event(d):
    body = d.get("body", "")
    to = render_to(d.get("to", ["*"]))
    full = f"message from={d['from']} ts={d['ts']} to={to} body={json.dumps(body)}"
    if len(full) <= TRUNCATE_THRESHOLD:
        return full
    preview = safe_preview_inner(body)
    return (f"message from={d['from']} ts={d['ts']} to={to} "
            f"chars={len(body)} truncated=true preview=\"{preview}\"")


def render_filesystem_event(d):
    parts = [f"filesystem from={d['from']} op={d.get('op')} "
             f"path={display_path(d.get('path', ''))}"]
    for k in ("size", "lines", "local"):
        if k in d:
            parts.append(f"{k}={d[k]}")
    parts.append(f"to={render_to(d.get('to', ['*']))}")
    return " ".join(parts)


def download_to_mirror(client, prefix, slug, sender, wire_path,
                       expect_size=None, expect_lines=None):
    """Download a published blob into the local mirror; return the local Path.

    Mirror layout is deterministic - ~/.cccp/<slug>/<sender>/<wire_path>, e.g.
    ~/.cccp/work-on-cccp/alice@hostA/files/home/alice/build.log - so any follow-up tool
    can read the file by its known path.

    If the publisher's claimed size / line count are given, the downloaded bytes
    are verified against them and a mismatch raises BlobError. This is an
    everybody-trusts-everybody environment, so the check surfaces bugs, not
    attackers.
    """
    st, body = client.get(f"{prefix}/{slug}/{sender}/{wire_path}")
    if st != 200:
        raise BlobError(st, b"download failed")
    if expect_size is not None and len(body) != expect_size:
        raise BlobError(0, f"{wire_path}: got {len(body)} bytes, "
                           f"publisher claimed {expect_size}".encode())
    if expect_lines is not None and body.count(b"\n") != expect_lines:
        raise BlobError(0, f"{wire_path}: got {body.count(chr(10).encode())} "
                           f"lines, publisher claimed {expect_lines}".encode())
    dest = LOCAL_MIRROR / slug / sender / wire_path
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_bytes(body)
    return dest


# ---------- watchtower ----------

class Watchtower:
    """Polls the cell prefix and emits one event line per new dispatch, join, or
    leave. A pure live-event stream: it skips backlog at startup (no replay) and
    has no local state - identity and history live in the container."""

    def __init__(self, client, prefix, slug, me, idle_initial, idle_max=IDLE_MAX_SECONDS):
        self.client = client
        self.prefix = prefix
        self.slug = slug
        self.me = me
        self.head = f"{prefix}/{slug}/"
        self.hwm = {}        # comrade -> bytes consumed of their gazette
        self.known = set()   # comrades already seen (join emitted)
        self.gone = set()    # comrades whose gone.json we've seen (leave emitted)
        self.stop = False
        # Idle backoff: start at idle_initial, double after each idle emission up
        # to idle_max, reset to idle_initial on any activity. idle_initial=0
        # disables idle events entirely.
        self.idle_initial = idle_initial
        self.idle_max = idle_max
        self.idle_current = idle_initial
        self.last_activity = time.monotonic()
        self.idle_due = self.last_activity + idle_initial
        # Adaptive poll cadence: ladder_step is the next index into POLL_LADDER;
        # -1 means "the next poll is the first since reset" so _next_sleep will
        # pre-increment to 0 and return LADDER[0] (the fast cadence). Any real
        # event or SIGUSR1 sets ladder_step back to -1. _interrupt breaks the
        # inter-poll sleep so SIGTERM/SIGINT/SIGUSR1 take effect within ms even
        # mid-60s gap.
        self.ladder_step = -1
        self._interrupt = threading.Event()
        self.wake_requested = False

    def _emit(self, line):
        print(line, flush=True)

    @staticmethod
    def _format_quiet(seconds):
        """Compact label for the elapsed silence on an idle event - minutes up to
        the hour, then hours. Keeps `quiet=24h` from rendering as `quiet=1440m`."""
        minutes = round(seconds / 60)
        if minutes < 60:
            return f"{minutes}m"
        return f"{round(minutes / 60)}h"

    def _next_sleep(self):
        """Advance one rung up the ladder (capped) and return the gap before the
        next poll. Reset (ladder_step = -1) on any activity or SIGUSR1 wake."""
        self.ladder_step = min(self.ladder_step + 1, len(POLL_LADDER) - 1)
        return POLL_LADDER[self.ladder_step]

    def _scan(self):
        """Group the cell prefix listing into per-comrade state."""
        gazettes, gone_now, comrades = {}, set(), set()
        for name, props in self.client.list(self.head).items():
            rest = name[len(self.head):]
            if "/" not in rest:
                continue
            comrade, leaf = rest.split("/", 1)
            comrades.add(comrade)
            if leaf == "gazette.jsonl":
                gazettes[comrade] = props["size"]
            elif leaf == "gone.json":
                gone_now.add(comrade)
        return comrades, gazettes, gone_now

    def initial_scan(self):
        """Register what's already present without replaying it or emitting joins."""
        comrades, gazettes, gone_now = self._scan()
        self.known |= comrades
        self.gone |= gone_now
        for comrade, size in gazettes.items():
            self.hwm[comrade] = size   # skip existing backlog

    def run(self):
        # Rejoin: clear any stale gone.json left by a previous session.
        self.client.request("DELETE", f"{self.head}{self.me}/gone.json")
        self.initial_scan()
        self._emit(f"ready {self.me} slug={self.slug}")
        # Start the idle clock from "fully up", after the network-bound startup.
        self.last_activity = time.monotonic()
        self.idle_current = self.idle_initial
        self.idle_due = self.last_activity + self.idle_initial
        self.ladder_step = -1
        signal.signal(signal.SIGTERM, self._on_signal)
        signal.signal(signal.SIGINT, self._on_signal)
        signal.signal(signal.SIGUSR1, self._on_wake)
        while not self.stop:
            try:
                self._poll_once()
            except Exception as e:
                print(f"watchtower error: {e}", file=sys.stderr)
            if self.stop:
                break
            # Event.wait so SIGTERM/SIGINT/SIGUSR1 can break the sleep promptly;
            # Python 3 time.sleep is not interruptible by signals (PEP 475).
            if self._interrupt.wait(timeout=self._next_sleep()):
                self._interrupt.clear()
                if self.wake_requested:
                    self.wake_requested = False
                    self.last_activity = time.monotonic()
                    self.ladder_step = -1

    def _on_signal(self, *_):
        self.stop = True
        self._interrupt.set()

    def _on_wake(self, *_):
        self.wake_requested = True
        self._interrupt.set()

    def _poll_once(self):
        comrades, gazettes, gone_now = self._scan()
        if self.me in gone_now:
            self._emit(f"left slug={self.slug}")
            self.stop = True
            return
        # Membership events emit in detection order, before the same poll's
        # message events (sorted by ts) - so a join always reads before the
        # joiner's first message, even though its synthetic ts is later.
        membership = []
        messages = []   # (ts, line)

        for comrade in comrades - self.known:
            self.known.add(comrade)
            if comrade not in gone_now:
                membership.append(f"join from={comrade}")

        for comrade in gone_now - self.gone:
            self.gone.add(comrade)
            reason = ""
            gst, gbody = self.client.get(f"{self.head}{comrade}/gone.json")
            if gst == 200:
                try:
                    reason = json.loads(gbody).get("reason", "") or ""
                except ValueError:
                    pass
            membership.append(f"leave from={comrade} reason={json.dumps(reason)}")

        for comrade, size in gazettes.items():
            if comrade == self.me:
                continue  # don't echo my own dispatches back to me
            offset = self.hwm.get(comrade, 0)
            if size <= offset:
                continue
            st, data = self.client.get_range(
                f"{self.head}{comrade}/gazette.jsonl", offset)
            if st not in (200, 206):
                continue
            consumed = 0
            for chunk in data.splitlines(keepends=True):
                if not chunk.endswith(b"\n"):
                    break  # partial trailing line; pick it up next poll
                consumed += len(chunk)
                try:
                    d = json.loads(chunk)
                except ValueError:
                    continue
                line = self._render(d)
                if line:
                    messages.append((d.get("ts", now_iso()), line))
            self.hwm[comrade] = offset + consumed

        for line in membership:
            self._emit(line)
        messages.sort(key=lambda x: x[0])
        for _, line in messages:
            self._emit(line)

        # Idle heartbeat: reassure Claude that a quiet line is healthy, not dead.
        # Backoff: each idle emission doubles the interval (capped at idle_max),
        # so a long-silent cell stops nagging Claude. Activity resets to initial.
        now = time.monotonic()
        if membership or messages:
            self.last_activity = now
            self.idle_current = self.idle_initial
            self.idle_due = now + self.idle_initial
            self.ladder_step = -1     # back to fast poll on any real event
        elif self.idle_initial > 0 and now >= self.idle_due:
            self._emit(f"idle quiet={self._format_quiet(now - self.last_activity)}")
            self.idle_current = min(self.idle_current * 2, self.idle_max)
            self.idle_due = now + self.idle_current

    def _render(self, d):
        if not addressed_to_me(d.get("to") or ["*"], self.me):
            return None
        t = d.get("type")
        if t == "message":
            return render_message_event(d)
        if t == "filesystem":
            return self._render_filesystem(d)
        return None

    def _render_filesystem(self, d):
        """Hybrid file handling: auto-download a published file small enough not
        to stall the poll loop and add its local path to the event; just announce
        larger ones for `cccp pull`. On unpublish, drop the mirror copy."""
        op, wire_path = d.get("op"), d.get("path", "")
        if op == "publish" and d.get("size", 0) <= AUTODOWNLOAD_MAX:
            try:
                local = download_to_mirror(self.client, self.prefix, self.slug,
                                           d["from"], wire_path,
                                           expect_size=d.get("size"),
                                           expect_lines=d.get("lines"))
                d = {**d, "local": str(local)}
            except (BlobError, OSError) as e:
                print(f"cccp watchtower: auto-download skipped: {e}",
                      file=sys.stderr)  # announce anyway; Claude can `cccp pull` it
        elif op == "unpublish":
            try:
                (LOCAL_MIRROR / self.slug / d["from"] / wire_path).unlink(
                    missing_ok=True)
            except OSError:
                pass
        return render_filesystem_event(d)


# ---------- subcommands ----------

def cmd_init(args):
    """Render-time helper: resolve identity + roster, print the block the skill
    string-substitutes into Claude's view so it starts already oriented.

    The skill passes just the first /cccp argument (`!`cccp init '$0'``) - the
    cell name - so freeform trailing context never reaches the shell. The name
    is slugified; the slug is the cell's one identity everywhere.
    """
    try:
        slug = slugify(args.name)
    except ValueError as e:
        sys.exit(f"error: {e}")
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    me = claim_identity(client, cfg["PREFIX"], slug)
    roster = cell_roster(client, cfg["PREFIX"], slug)
    others = [c for c in roster if c != me]

    print(f"You are comrade `{me}` in CCCP cell `{slug}`.")
    # Not super useful to Claude
    #print(f"Cell store: {cfg['ACCOUNT']}/{cfg['CONTAINER']}/{cfg['PREFIX']}/{slug}/")
    if others:
        print(f"Roster ({len(roster)}): " + ", ".join(roster))
    else:
        print("Roster: just you - this cell is empty so far.")
    print("No history loaded. Introduce yourself to the cell with `cccp dispatch`.")


def cmd_dispatch(args):
    """Append a message to my gazette - the whole of sending, in v2."""
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    slug = slugify(args.cell)
    me = claim_identity(client, cfg["PREFIX"], slug)
    d = {
        "type": "message",
        "ts": now_iso(),
        "from": me,
        "to": args.to if args.to else ["*"],
        "body": args.body,
    }
    append_dispatch(client, cfg["PREFIX"], slug, me, d)


def cmd_watchtower(args):
    """Run the long-lived live-event stream for a cell (under the Monitor tool)."""
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    slug = slugify(args.cell)
    me = claim_identity(client, cfg["PREFIX"], slug)
    Watchtower(client, cfg["PREFIX"], slug, me, args.idle * 60).run()


def cmd_wake(args):
    """SIGUSR1 any local watchtower for this cell -- reset to fast-poll mode and
    poll immediately. Use when you know an event is waiting and don't want to
    wait out the current idle gap.

    Sibling-session caveat: this uses pkill -USR1 against the argv pattern
    `cccp watchtower <slug>`, which is byte-identical across sibling Claude
    sessions on the same host+user watching the same cell. All such siblings
    will be woken. The collateral cost is trivial - the spurious sibling spends
    a few extra seconds in fast-poll before its ladder reasserts - so this is
    the documented, accepted side-effect. Surgical per-session signalling via
    a pidfile keyed on CLAUDE_CODE_SESSION_ID is captured in TODO for later.
    """
    slug = slugify(args.cell)
    # Anchored regex: cccp watchtower foo must not match cccp watchtower foo-bar.
    # Slugs are [a-z0-9-] only (slugify), so re.escape is belt-and-suspenders.
    # POSIX ERE only (BSD pkill on macOS, procps pkill on Linux): literal space
    # alternation, not \s. pkill is built-in on both, no homebrew/extra packages.
    pattern = rf"cccp watchtower {re.escape(slug)}( |$)"
    r = subprocess.run(["pkill", "-USR1", "-f", pattern], capture_output=True)
    if r.returncode == 0:
        print(f"woke watchtower(s) for cell {slug!r}")
    elif r.returncode == 1:
        sys.exit(f"no local watchtower found for cell {slug!r}")
    else:
        sys.exit(f"pkill failed: {r.stderr.decode().strip() or r.returncode}")


def cmd_leave(args):
    """Write gone.json - an intentional departure. A watchtower for this session
    notices it on the next poll and exits."""
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    slug = slugify(args.cell)
    me = claim_identity(client, cfg["PREFIX"], slug)
    gone = {"ts": now_iso(), "reason": args.reason or ""}
    client.put_block(f"{cfg['PREFIX']}/{slug}/{me}/gone.json",
                     json.dumps(gone).encode())


def cmd_read(args):
    """Print cell message history - the on-demand history tool. Filter by sender
    (--from), recipient (--to), and select with --ts or --last."""
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    slug = slugify(args.cell)
    prefix = cfg["PREFIX"]

    senders = [args.from_] if args.from_ else cell_roster(client, prefix, slug)
    msgs = []
    for sender in senders:
        st, body = client.get(gazette_path(prefix, slug, sender))
        if st != 200:
            continue
        for line in body.splitlines():
            try:
                d = json.loads(line)
            except ValueError:
                continue
            if d.get("type") == "message":
                msgs.append(d)

    if args.to:
        msgs = [m for m in msgs if addressed_to_me(m.get("to") or ["*"], args.to)]
    msgs.sort(key=lambda m: m.get("ts", ""))

    if args.ts:
        m = next((m for m in msgs if m.get("ts") == args.ts), None)
        if not m:
            sys.exit(f"error: no message with ts={args.ts!r}")
        body = m.get("body", "")
        sys.stdout.write(body if body.endswith("\n") else body + "\n")
        return

    if args.last is not None:
        if args.last < 1:
            sys.exit("error: --last must be >= 1")
        msgs = msgs[-args.last:]

    if not msgs:
        print("(no messages)")
        return
    for m in msgs:
        print(f"from={m.get('from')} to={render_to(m.get('to', ['*']))} ts={m.get('ts')}")
        print(m.get("body", ""))
        print()


def cmd_rm(args):
    """Delete a cell and all its blobs. Destructive and user-directed: prints a
    summary first, and only deletes when --yes is given."""
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    slug = slugify(args.cell)
    head = f"{cfg['PREFIX']}/{slug}/"
    blobs = list(client.list(head))
    if not blobs:
        print(f"cell {slug!r} is empty or does not exist - nothing to delete")
        return
    comrades = sorted({n[len(head):].split("/", 1)[0]
                       for n in blobs if "/" in n[len(head):]})
    print(f"cell {slug!r}: {len(blobs)} blobs across {len(comrades)} comrades "
          f"({', '.join(comrades)})")
    if not args.yes:
        print("dry run - pass --yes to actually delete")
        return
    for name in blobs:
        st = client.request("DELETE", name)[0]
        print(f"deleted {name} -> {st}")
    print(f"cell {slug!r} removed")


def cmd_publish(args):
    """Upload a file as a block blob under my files/ area and announce it in my
    gazette. Single-PUT only - files over PUBLISH_MAX need ad-hoc staging."""
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    slug = slugify(args.cell)
    me = claim_identity(client, cfg["PREFIX"], slug)

    src = Path(os.path.abspath(os.path.expanduser(args.path)))
    if not src.is_file():
        sys.exit(f"error: not a regular file: {src}")
    size = src.stat().st_size
    if size > PUBLISH_MAX:
        sys.exit(
            f"error: {src} is {size} bytes, over the {PUBLISH_MAX}-byte single-PUT "
            f"limit. cccp publish does one urllib PUT - it does not stage block "
            f"lists. To publish a file this large, either:\n"
            f"  1. ask the user to install azcopy (pip/brew) and upload with it, or\n"
            f"  2. write an ad-hoc Put Block + Put Block List uploader, reading this "
            f"script ({__file__}) as a reference for the SAS/REST setup.")

    rel = str(src).lstrip("/")
    data = src.read_bytes()
    st = client.put_block(f"{cfg['PREFIX']}/{slug}/{me}/files/{rel}", data)
    if st != 201:
        raise BlobError(st, b"publish upload failed")

    d = {"type": "filesystem", "op": "publish", "ts": now_iso(), "from": me,
         "to": args.to if args.to else ["*"], "path": f"files/{rel}", "size": size}
    if src.suffix.lower() in TEXT_EXTENSIONS:
        d["lines"] = data.count(b"\n")
    append_dispatch(client, cfg["PREFIX"], slug, me, d)
    print(f"published {rel} ({size} bytes)")


def cmd_unpublish(args):
    """Delete a previously-published file blob and announce the withdrawal.
    Uses the same path that was given to publish."""
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    slug = slugify(args.cell)
    me = claim_identity(client, cfg["PREFIX"], slug)

    src = Path(os.path.abspath(os.path.expanduser(args.path)))
    rel = str(src).lstrip("/")
    client.request("DELETE", f"{cfg['PREFIX']}/{slug}/{me}/files/{rel}")  # 404 ok
    d = {"type": "filesystem", "op": "unpublish", "ts": now_iso(), "from": me,
         "to": args.to if args.to else ["*"], "path": f"files/{rel}"}
    append_dispatch(client, cfg["PREFIX"], slug, me, d)
    print(f"unpublished {rel}")


def cmd_pull(args):
    """Download published files matching the given path expressions into the
    local mirror. Synchronous; on success it is silent and exits 0, so Claude
    can chain it: `cccp pull <cell> <paths> && <follow-up>`."""
    cfg = resolve_config()
    client = BlobClient(cfg["ACCOUNT"], cfg["CONTAINER"], cfg["SAS"])
    slug = slugify(args.cell)
    prefix = cfg["PREFIX"]

    # Catalogue currently-published files across all gazettes; a later unpublish
    # cancels an earlier publish of the same (sender, path). The value is the
    # publish dispatch, kept so its claimed size / line count can be verified.
    catalogue = {}  # (sender, wire_path) -> publish dispatch dict
    for sender in cell_roster(client, prefix, slug):
        st, body = client.get(gazette_path(prefix, slug, sender))
        if st != 200:
            continue
        for line in body.splitlines():
            try:
                d = json.loads(line)
            except ValueError:
                continue
            if d.get("type") != "filesystem":
                continue
            key = (sender, d.get("path", ""))
            if d.get("op") == "publish":
                catalogue[key] = d
            elif d.get("op") == "unpublish":
                catalogue.pop(key, None)

    # Match each published file's original path against the expressions: an exact
    # match, or the expression is a directory prefix of it.
    exprs = [os.path.abspath(os.path.expanduser(e)) for e in args.expr]
    wanted = [(sender, wp) for (sender, wp) in catalogue
              if any(display_path(wp) == e
                     or display_path(wp).startswith(e.rstrip("/") + "/")
                     for e in exprs)]
    if not wanted:
        sys.exit(f"error: no published files match {args.expr}")
    for sender, wire_path in wanted:
        meta = catalogue[(sender, wire_path)]
        try:
            download_to_mirror(client, prefix, slug, sender, wire_path,
                               expect_size=meta.get("size"),
                               expect_lines=meta.get("lines"))
        except BlobError as e:
            sys.exit(f"error: {e}")
    # success: silent, exit 0


# ---------- argparse ----------

def build_parser():
    p = argparse.ArgumentParser(
        prog="cccp",
        description="Claude-to-Claude Communication Protocol (v2, Azure Blob).",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    init = sub.add_parser("init", help="Resolve identity + roster for a cell "
                                       "(render-time helper for the skill).")
    init.add_argument("name", help="Cell name - the skill passes just the first "
                                   "/cccp argument ($0).")
    init.set_defaults(func=cmd_init)

    disp = sub.add_parser("dispatch", help="Send a message to a cell.")
    disp.add_argument("cell", help="Cell slug.")
    disp.add_argument("--to", action="append", default=[], metavar="COMRADE",
                      help="Repeatable. Comrade id; omit for broadcast.")
    disp.add_argument("body", help="Message text.")
    disp.set_defaults(func=cmd_dispatch)

    wt = sub.add_parser("watchtower",
                        help="Stream live cell events (run under the Monitor tool).")
    wt.add_argument("cell", help="Cell slug.")
    wt.add_argument("--idle", type=int, default=30, metavar="MIN",
                    help="Initial silence (minutes) before the first `idle` "
                         "heartbeat (default 30; 0 disables). Each subsequent "
                         "silent interval doubles, capped at 24h, and resets to "
                         "this initial value on any activity.")
    wt.set_defaults(func=cmd_watchtower)

    wk = sub.add_parser("wake",
                        help="SIGUSR1 the local watchtower for this cell so it "
                             "polls immediately and resets the cadence ladder.")
    wk.add_argument("cell", help="Cell slug.")
    wk.set_defaults(func=cmd_wake)

    lv = sub.add_parser("leave",
                        help="Leave a cell (writes gone.json; your watchtower exits).")
    lv.add_argument("cell", help="Cell slug.")
    lv.add_argument("--reason", default=None, help="Optional departure reason.")
    lv.set_defaults(func=cmd_leave)

    rd = sub.add_parser("read", help="Print cell message history.")
    rd.add_argument("cell", help="Cell slug.")
    rd.add_argument("--from", dest="from_", metavar="COMRADE",
                    help="Only this sender's messages (default: all comrades).")
    rd.add_argument("--to", metavar="COMRADE",
                    help="Only messages a given comrade would receive (incl. broadcasts).")
    g = rd.add_mutually_exclusive_group()
    g.add_argument("--ts", help="Print only the message with this exact timestamp.")
    g.add_argument("--last", type=int, metavar="N",
                   help="Print only the last N messages.")
    rd.set_defaults(func=cmd_read)

    rm = sub.add_parser("rm",
                        help="Delete a cell and all its blobs (user-directed).")
    rm.add_argument("cell", help="Cell slug.")
    rm.add_argument("--yes", action="store_true",
                    help="Actually delete; without it, this is a dry run.")
    rm.set_defaults(func=cmd_rm)

    pub = sub.add_parser("publish", help="Share a file with a cell.")
    pub.add_argument("cell", help="Cell slug.")
    pub.add_argument("--to", action="append", default=[], metavar="COMRADE",
                     help="Repeatable. Comrade id; omit for broadcast.")
    pub.add_argument("path", help="Path of the file to publish.")
    pub.set_defaults(func=cmd_publish)

    unp = sub.add_parser("unpublish",
                         help="Withdraw a previously-published file.")
    unp.add_argument("cell", help="Cell slug.")
    unp.add_argument("--to", action="append", default=[], metavar="COMRADE",
                     help="Repeatable. Comrade id; omit for broadcast.")
    unp.add_argument("path", help="Path of the file to withdraw (as published).")
    unp.set_defaults(func=cmd_unpublish)

    pl = sub.add_parser("pull",
                        help="Download published files matching path expressions "
                             "into the local mirror (silent + exit 0 on success).")
    pl.add_argument("cell", help="Cell slug.")
    pl.add_argument("expr", nargs="+", metavar="PATH",
                    help="File or directory path(s), as originally published.")
    pl.set_defaults(func=cmd_pull)

    return p


def main(argv=None):
    args = build_parser().parse_args(argv)
    args.func(args)


if __name__ == "__main__":
    main()
