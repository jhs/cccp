#!/usr/bin/env python3
"""cccp - Claude-to-Claude Communication Program.

Comrades rendezvous through one shared blob store - every comrade reads and
writes the same store, with no peer-to-peer connections. The store is a pluggable
backend behind a small verb set (list / read / append / delete); see BACKENDS.
Two ship today:

    local-fs (default)  Files under the plugin data dir. Zero setup, but same
                        host + same OS user only.
    azure-blob          A shared Azure Blob container reachable from any host,
                        user, or network. Pure stdlib urllib against the Blob
                        REST API, authenticated by a container-scoped SAS - no
                        SDK, no azcopy, so it runs anywhere Python 3 does.

Storage layout (a cell is a store + prefix + slug; local-fs uses no prefix):

    <prefix>/<slug>/gazettes/<comrade-id>.jsonl   append-only, their messages
    <prefix>/<slug>/files/<comrade-id>/<path>     shared files

A comrade is registered in a cell purely by having a gazette - identity is a
local `user@host:<session>` computed offline, so there is no claim blob and no
coordination step; comrades are discovered when their first message arrives.

bin/cccp is an executable script, not an importable module. When an ad-hoc
one-off needs the REST logic (e.g. the large-file staging fallback), read this
file as a reference implementation rather than importing it.

Subcommands:
    backend     Print the active data backend; subcommands config/check/use.
    skill       Emit a skill's body (SKILL.md render-time helper; hidden).
    dispatch    Send a message to a cell.
    watchtower  Stream live cell events (run under the Monitor tool).
    read        Print cell message history.
    rm          Delete a cell and all its blobs (user-directed).
    publish     Share a file with a cell.
    unpublish   Withdraw a previously-published file.
    pull        Download published files into the local mirror.
"""

import argparse
import contextlib
import email.utils
import json
import logging
import logging.handlers
import os
import platform
import pwd
import re
import shlex
import signal
import socket
import subprocess
import sys
import threading
import time
import traceback
import urllib.error
import urllib.parse
import urllib.request
import xml.etree.ElementTree as ET
from datetime import datetime, timedelta, timezone
from pathlib import Path

API_VERSION = "2023-11-03"
CCCP_VERSION = "3.0.0"     # Shown on the watchtower `ready` line (v=...) so a
                           # comrade's Claude can see which build it is running.
                           # Cosmetic only - nothing reads it. KEEP EQUAL to the
                           # version in .claude-plugin/plugin.json - the single
                           # source of truth (the marketplace entry carries no
                           # version; Claude Code resolves plugin.json first). Bump
                           # both together each release so the ready-line v= matches
                           # the installed plugin.
# A prefix carves namespace room inside one flat shared container/bucket, so it is
# azure/S3-only in practice: local-fs gets that isolation from its own root dir and
# exposes no prefix key at all (empty prefix, no __default__ folder). Every path
# builder tolerates an empty prefix.
DEFAULT_PREFIX = "__default__"
POLL_LADDER = (            # seconds; the adaptive inter-poll gap. First entry is
    2, 5, 15, 30, 60,      # the "fast" cadence used right after activity; each
    120, 180, 300,         # no-activity poll advances one rung. Last entry is
)                          # the cap (5min), stays there indefinitely while
                           # idle. Any real event resets back to entry 0;
                           # SIGUSR1 (cccp wake) does the same plus polls
                           # immediately. 2s floor because polling is a network
                           # LIST against the backend and a comrade takes
                           # multiple seconds just to emit a message anyway.
TRUNCATE_THRESHOLD = 500   # max chars per watchtower stdout line (Monitor cuts at 500)
IDLE_MAX_SECONDS = 24 * 3600   # cap for the idle backoff - past this, idles fire
                               # at most once a day so a long-silent watchtower
                               # stops forcing Claude to wake and respond
PUBLISH_MAX = 256 * 1024 * 1024   # single-PUT publish ceiling; larger needs staging
AUTODOWNLOAD_MAX_DEFAULT = "1m"   # watchtower auto-downloads published files at or
                                  # under this size; larger ones are only announced
                                  # (Claude fetches them with `cccp pull`). Bounded
                                  # by what downloads fast enough not to stall the
                                  # poll loop - not by "how big a file is".
                                  # Tunable: CCCP_AUTODOWNLOAD_MAX (parse_size
                                  # syntax); kept as its human spelling so the
                                  # config dump can print it verbatim.
DEBUG_LOG_MAX_BYTES = 10 * 1024 * 1024    # per debug.log; rotates to keep 5 backups
DEBUG_LOG_BACKUPS = 5                     # so worst case ~60 MB per (cell, comrade)
TEXT_EXTENSIONS = {
    ".txt", ".md", ".rst", ".html", ".htm", ".xml", ".csv", ".tsv", ".json",
    ".yaml", ".yml", ".toml", ".ini", ".cfg", ".conf", ".log", ".sh", ".bash",
    ".zsh", ".py", ".js", ".ts", ".jsx", ".tsx", ".c", ".h", ".cpp", ".hpp",
    ".cc", ".go", ".rs", ".java", ".rb", ".pl", ".php", ".lua", ".sql", ".css",
    ".scss", ".vue", ".svelte", ".tf", ".hcl", ".env", ".gitignore",
}


# ---------- identity & misc helpers ----------

_DURATION_FULL = re.compile(r"(?:\d+[smh])+")
_DURATION_PART = re.compile(r"(\d+)([smh])")
_UNIT_SECONDS = {"s": 1, "m": 60, "h": 3600}


def parse_duration(text):
    """A compact duration -> whole seconds: '180s', '10m', '3h30m'. Returns None
    for anything not well-formed, so a caller can reject the raw input rather
    than silently misread it (a mistyped deadline must not become a wrong one)."""
    if not text or not _DURATION_FULL.fullmatch(text):
        return None
    return sum(int(n) * _UNIT_SECONDS[u] for n, u in _DURATION_PART.findall(text))


def parse_size(text):
    """A compact byte size -> whole bytes: '4096', '512k', '10m', '1g' (suffix
    case-insensitive, optional trailing 'b'). Returns None for anything not
    well-formed, so a caller can reject the raw input rather than silently
    misread it - exactly parse_duration's contract, for sizes."""
    m = re.fullmatch(r"(\d+)\s*([kmg]?)b?", str(text).strip().lower())
    if not m:
        return None
    return int(m.group(1)) * {"": 1, "k": 1024, "m": 1024 ** 2,
                              "g": 1024 ** 3}[m.group(2)]


def format_duration(seconds):
    """Seconds -> the compact form events use, inverse of parse_duration: 45s,
    3m7s, 10m, 1h7s, 3h29m58s.

    Every non-zero component is kept, even seconds at hour scale. Rounding them
    off would look tidier but breaks the arithmetic a reader checks against:
    with limit=3h30m and took=2s, an early= of '3h29m' does not reconcile, and a
    reader who cannot make the numbers add up has to stop and work out why -
    which is worse than not pre-computing them at all."""
    seconds = max(0, int(round(seconds)))
    if seconds < 60:
        return f"{seconds}s"
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    out = f"{h}h" if h else ""
    out += f"{m}m" if m else ""
    out += f"{s}s" if s else ""
    return out or "0s"


def now_iso():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%fZ")


def current_user():
    return pwd.getpwuid(os.getuid()).pw_name


def short_hostname():
    return socket.gethostname().split(".")[0]


def base_comrade_id():
    """The machine/account part of a comrade id: user@host. comrade_id() appends
    the session suffix; a few read-only commands use this bare form for a log
    path where the exact id doesn't matter."""
    return f"{current_user()}@{short_hostname()}"


def slugify(name):
    s = re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")
    if not s:
        raise ValueError(f"Cell name {name!r} produced an empty slug")
    return s


def current_session_id():
    """The Claude Code session UUID, exported as CLAUDE_CODE_SESSION_ID.

    Stable for the whole conversation, including across `claude --resume`. Every
    cccp invocation from one Claude session reads the same value, so all of that
    session's processes (dispatch / watchtower / skill) derive the identical
    comrade id with no local state file. Truncated to 6 chars, it is the suffix
    of every comrade id (see comrade_id).

    Non-Claude callers (manual testing, scripts) should set CCCP_COMRADE_ID to
    supply an explicit id and bypass session-derived identity entirely.
    """
    sid = os.environ.get("CLAUDE_CODE_SESSION_ID")
    if not sid:
        sys.exit("error: CLAUDE_CODE_SESSION_ID is not set; cccp must run under "
                 "Claude Code, or set CCCP_COMRADE_ID to supply an explicit id")
    return sid


# ---------- plugin data tree ----------
#
# One namespace, $CCCP_PLUGIN_DATA, split by role the way XDG and /var split data
# from cache. The load-bearing line is backend/ vs. everything else:
#   settings              global cccp state (active backend, ...)
#   backend/<name>/       per-backend shared state; backend/local-fs/ IS the
#                         authoritative local cell store, azure-blob/ holds only
#                         connection config
#   mirror/               cache: pulled files, aliases, per-cell debug + watchtower logs
#   telemetry/            cache: harvested session data (token-aware)
#   run/                  ephemeral inter-process runtime state (the /var/run of
#                         the tree): watchtower inboxes today, pidfiles later
#
# backend/local-fs/ is the ONLY authoritative data in the tree: it IS the local
# cell's message log, and deleting it loses messages permanently. That is the
# exception, not the rule - backend/azure-blob/ holds just a pointer + credentials
# (re-runnable), and mirror/, telemetry/ and run/ are reconstructible caches, safe
# to wipe. A future `cccp gc` should be able to clear those three and be
# structurally incapable of reaching backend/.
# Claude Code exports CCCP_PLUGIN_DATA (the SessionStart hook in hooks/), so it is
# always set inside a session. When it is missing, cccp stops rather than guessing.

def plugin_data_dir():
    """The root every path in this tree hangs off. There is deliberately NO default.

    Guessing a root is not a convenience here, it is data loss with a friendly
    face: backend/local-fs/ IS the authoritative cell store, so a wrong root sends
    messages to a store nobody reads and writes config where the plugin will never
    look - silently, and looking exactly like success. It is the same failure the
    backend rules already forbid ('never silently downgrade'), one level down.

    Nor is there a right value to guess: the data dir's name carries the
    marketplace the plugin was installed from (cccp-<marketplace>), which this
    script cannot know. So an unset var is a hard error carrying the fix, matching
    what bin/claude-tokens already does."""
    d = os.environ.get("CCCP_PLUGIN_DATA")
    if not d:
        sys.exit(
            "ERROR: CCCP_PLUGIN_DATA is not set, so cccp has no data directory.\n"
            "\n"
            "Inside a Claude Code session, the plugin's SessionStart hook\n"
            "exports it. If you are seeing this there, the plugin is not enabled "
            "- check `/plugin`.\n"
            "\n"
            "To run cccp by hand outside a session, point it at the plugin's "
            "data dir first, e.g.\n"
            "\n"
            "export CCCP_PLUGIN_DATA=${CLAUDE_CONFIG_DIR:-~/.claude}"
            "/plugins/data/cccp-inline\n"
        )
    return Path(d)


def mirror_dir():
    """Local cache of pulled/auto-downloaded files, aliases, and per-cell logs -
    reconstructible, safe to delete (successor to the old ~/.cccp)."""
    return plugin_data_dir() / "mirror"


def run_dir():
    """Ephemeral inter-process runtime state - the /var/run of the tree. Neither
    cache nor authoritative: everything here is meaningless once the process that
    owns it is gone, and is recreated by the next one that needs it."""
    return plugin_data_dir() / "run"


def backend_dir(name):
    """Shared state for one backend. backend/local-fs/ IS the local cell store
    (authoritative); backend/azure-blob/ holds only connection config."""
    return plugin_data_dir() / "backend" / name


def global_config_path():
    """The global config file (KEY=value), e.g. CCCP_ACTIVE_BACKEND, CCCP_DEBUG.
    Absent => local-fs, debug off. `cccp config` names it by its data-dir-relative
    path ("config"), so a reader can go from the dump straight to the file."""
    return plugin_data_dir() / "config"


# ---------- config resolution ----------

def _parse_cccp_env(path):
    """Parse a KEY=value file, returning only its CCCP_* keys."""
    cfg = {}
    for line in Path(path).read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        if k.startswith("CCCP_"):
            cfg[k] = v.strip()
    return cfg


DEFAULT_BACKEND = "local-fs"

# Backend registry: the one-line summary the @@BACKEND@@ skill header shows, the
# param names, and the prefix default. Every backend is addressed by
# CCCP_<BACKEND>_<KEY> keys (name upcased, '-'->'_'), so params never collide -
# across the tree's config files or across environment variables. A backend name
# must not collide with a global key stem (ACTIVE_BACKEND, DEBUG).
#
# `params` lists the non-secret params; `secrets` lists the secret ones, which
# are of course params too - each key is declared exactly once, and
# _backend_params() is the full set (a key repeated in both would be a bug, not
# a convention to maintain). A secret is never printed (see _fmt_param), and
# `cccp config` routes it to the scope's `secrets` file rather than `config` -
# same format, but a file nothing should ever read except cccp.
# `defaults` maps an OPTIONAL param to a zero-arg callable producing its
# effective value - lazy, because defaults like the local-fs root depend on
# CCCP_PLUGIN_DATA at call time. A param with a default is never "missing".
#
# Prose about what a backend IS lives in skills/setup/SKILL.md, not here: the CLI
# states facts and config, and the setup skill - which no chat session ever loads -
# is where a reader has room for the explanation.
BACKENDS = {
    "local-fs": {
        "summary": "Same host; same OS user unless ROOT points at a shared dir",
        "params": ("ROOT",),
        "secrets": (),
        "prefix_default": "",
        "defaults": {"ROOT": lambda: str(backend_dir("local-fs"))},
    },
    "azure-blob": {
        "summary": "Any host, user, or network; needs Azure + SAS",
        "params": ("ACCOUNT", "CONTAINER"),
        "secrets": ("SAS",),
        "prefix_default": DEFAULT_PREFIX,
    },
}


def _backend_params(spec):
    """All of one backend's param names: the declared non-secrets, then the
    secrets - which are params too, listed once (in `secrets` only)."""
    return tuple(spec["params"]) + tuple(spec["secrets"])


def _backend_key(backend, key):
    """The fully-qualified config key for one backend param: CCCP_<BACKEND>_<KEY>."""
    return f"CCCP_{backend.upper().replace('-', '_')}_{key}"


def _read_kv_file(path):
    """CCCP_* keys from a KEY=value file; {} if it is missing or unreadable."""
    try:
        return _parse_cccp_env(path)
    except OSError:
        return {}


def _env_layer():
    """The process-environment config layer: every CCCP_* var currently set."""
    return {k: v for k, v in os.environ.items() if k.startswith("CCCP_")}


def resolve_config():
    """Resolve the active backend and its config.

    Flat, self-namespacing KEY=value config (dotenv syntax), low -> high
    precedence; each scope splits into a `config` file and a format-identical
    `secrets` file, so secret values live in files nothing should ever read
    but cccp:

        config -> secrets                        global cccp state
          -> backend/<active>/config -> secrets  the active backend's params
            -> process env CCCP_*                 highest (direnv, CI, etc.)

    The active backend must resolve before its config file loads, so it comes from
    the global file + env first (default local-fs); then that backend's file joins
    the merge for the CCCP_<BACKEND>_* params. The active backend is never inferred
    from stray credentials and never silently downgraded: a selected-but-broken
    backend fails loudly in make_backend, not here. Returns
    {BACKEND, PARAMS, PREFIX, DEBUG, SOURCES}, where SOURCES maps each key any layer
    set to the list of layers that set it, low -> high precedence - each layer named
    by its data-dir-relative file path ("config", "backend/<name>/config") or "env".
    The last entry is the layer that won; earlier ones are shadowed. `cccp config`
    prints both, so an env var quietly overriding a config file is visible rather
    than puzzling.
    """
    env = _env_layer()
    global_file = _read_kv_file(global_config_path())

    # Active backend: global config file, overridden by process env
    # (default local-fs).
    backend = {**global_file, **env}.get("CCCP_ACTIVE_BACKEND") or DEFAULT_BACKEND
    spec = BACKENDS.get(backend)
    if spec is None:
        sys.exit(f"error: unknown backend {backend!r} (from CCCP_ACTIVE_BACKEND); "
                 f"known: {', '.join(sorted(BACKENDS))}")

    # Backend params: config < backend/<active>/config < process env. One ordered
    # layer list drives both the merge and the provenance map, so the two can never
    # disagree about which layer won a key: later layers overwrite earlier ones in
    # lockstep, exactly as {**global_file, **backend_file, **env} would.
    merged, sources = {}, {}
    for layer_name, layer in (
            ("config", global_file),
            ("secrets", _read_kv_file(plugin_data_dir() / "secrets")),
            (f"backend/{backend}/config",
             _read_kv_file(backend_dir(backend) / "config")),
            (f"backend/{backend}/secrets",
             _read_kv_file(backend_dir(backend) / "secrets")),
            ("env", env)):
        merged.update(layer)
        for k in layer:
            sources.setdefault(k, []).append(layer_name)
    params = {k.lower(): merged.get(_backend_key(backend, k))
              for k in _backend_params(spec)}
    # Optional params fall back to their registry default (lazy - see BACKENDS).
    # Baked in here so every consumer (make_backend, validate, the config dump)
    # sees the effective value; SOURCES stays empty for it, which is exactly
    # what renders as `default`.
    for k, default in spec.get("defaults", {}).items():
        if not params[k.lower()]:
            params[k.lower()] = default()
    prefix = merged.get(_backend_key(backend, "PREFIX")) or spec["prefix_default"]

    # Sizes are validated here, not at the use site: a malformed value must
    # fail the command loudly (parse_duration's contract), never quietly fall
    # back to the default - env is a config layer too and can inject garbage
    # no `cccp config` write ever vetted.
    raw_adl = merged.get("CCCP_AUTODOWNLOAD_MAX")
    if raw_adl is not None and parse_size(raw_adl) is None:
        sys.exit(f"error: CCCP_AUTODOWNLOAD_MAX {raw_adl!r} is not a size "
                 f"('4096', '512k', '10m', '1g')")

    return {
        "BACKEND": backend,
        "PARAMS": params,
        "PREFIX": prefix,
        "DEBUG": merged.get("CCCP_DEBUG"),
        "AUTODOWNLOAD_MAX": parse_size(raw_adl if raw_adl is not None
                                       else AUTODOWNLOAD_MAX_DEFAULT),
        "AUTODOWNLOAD_MAX_RAW": raw_adl if raw_adl is not None
                                else AUTODOWNLOAD_MAX_DEFAULT,
        "SOURCES": sources,
    }


# ---------- debug logging ----------

# A pure NullHandler logger that every entry point hands out by default. All
# `log.debug(...)` and `TimeLogger(...)` sites work against it as a no-op when
# CCCP_DEBUG is unset or falsy, so the rest of the script never branches on
# whether debug logging is enabled. Strip every `log.*` call from the source
# and the SKILL.md-facing contract (stdout protocol stream + the small stderr
# error prints) is unchanged - debug logging is purely additive.
_NULL_LOG = logging.getLogger("cccp.null")
_NULL_LOG.addHandler(logging.NullHandler())
_NULL_LOG.propagate = False
_NULL_LOG.setLevel(logging.CRITICAL + 1)


def _truthy(v):
    """CCCP_DEBUG is parsed as a boolean: unset/empty/0/false/no/off -> off."""
    return v is not None and str(v).strip().lower() not in (
        "", "0", "false", "no", "off")


def _kv(v):
    """Render a value for a key=val log field. Strings with whitespace or
    quote/backslash get JSON-quoted so a downstream parser can split on
    whitespace; everything else is bare."""
    if v is None:
        return "None"
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, (int, float)):
        return f"{v}"
    s = str(v)
    if not s or any(c.isspace() or c in '"\\' for c in s):
        return json.dumps(s)
    return s


class _MonoFilter(logging.Filter):
    """Inject record.mono = time.monotonic() at the log call site (not at format
    time, which would drift by formatter cost). Wall-clock millis come from the
    record's own `created`; this is the matched monotonic anchor."""

    def filter(self, record):
        record.mono = time.monotonic()
        return True


class _KVFormatter(logging.Formatter):
    """Format: <UTC ISO8601 millis> mono=<sec.ms> pid=<N> <message>.

    Wall-clock is what aligns logs across comrades (anchored on the Azure
    `Date` header for skew correction); monotonic is what aligns events within
    one log file regardless of NTP steps. pid is per-line because multiple
    cccp processes (watchtower, dispatch, init, ...) append to the same file.
    """

    def format(self, record):
        ct = time.gmtime(record.created)
        ts = time.strftime("%Y-%m-%dT%H:%M:%S", ct) + f".{int(record.msecs):03d}Z"
        return (f"{ts} mono={record.mono:.3f} pid={record.process} "
                f"{record.getMessage()}")


class TimeLogger:
    """Context manager that times its block and emits one duration line on
    exit. Inspired by companion/job.py's TimeLogger, pared to the essentials:
    no Start/Finish lines (the duration is the deliverable), no thread-local
    indent (single-threaded I/O), and `done(**fields)` for post-hoc metadata
    only knowable inside the block (HTTP status, bytes, response headers).

    On exception, the duration line still fires with exc=<ExcName>. The
    exception is not suppressed.
    """

    def __init__(self, log, ev, **fields):
        self.log = log
        self.ev = ev
        self.fields = fields
        self.t0 = None

    def __enter__(self):
        self.t0 = time.monotonic()
        return self

    def done(self, **fields):
        """Stash fields to emit on the duration line. Called from inside the
        block once the values (status, bytes, ...) are known."""
        self.fields.update(fields)

    def __exit__(self, exc_type, exc_val, exc_tb):
        dur_ms = (time.monotonic() - self.t0) * 1000
        parts = [f"ev={self.ev}", f"duration_ms={dur_ms:.1f}"]
        for k, v in self.fields.items():
            parts.append(f"{k}={_kv(v)}")
        if exc_type is not None:
            parts.append(f"exc={exc_type.__name__}")
        self.log.debug(" ".join(parts))
        return False


def _emit_startup_header(log, slug, me, argv):
    """The first line of each invocation - self-describing provenance so a log
    file copied out of its directory tree is still analyzable, and so an
    interleaved file (watchtower + dispatch + ...) is greppable by pid."""
    log.debug(
        f"ev=cccp_start session={_kv(os.environ.get('CLAUDE_CODE_SESSION_ID', ''))} "
        f"comrade={_kv(me)} slug={_kv(slug)} "
        f"argv={_kv(' '.join(shlex.quote(a) for a in argv))} "
        f"host={_kv(socket.gethostname())} cwd={_kv(os.getcwd())} "
        f"python={_kv(platform.python_version())} start={now_iso()}")


def setup_logging(cfg, slug, me, argv):
    """Return a logger. If CCCP_DEBUG is falsy/unset, returns _NULL_LOG and
    nothing is written. If truthy, installs a RotatingFileHandler at
    <mirror>/<slug>/<me>/cccp-debug.log and emits the startup header.

    Identity is now a local computation (comrade_id), so there are no pre-logging
    HTTP calls to miss - the first network call a subcommand makes happens after
    this returns. The lag investigation this debug feature exists for happens in
    the steady-state poll loop, which is fully covered.

    Fails closed: any setup error degrades to the NullHandler logger with a
    one-line warning on stderr, never breaking the caller.
    """
    if not _truthy(cfg.get("DEBUG")):
        return _NULL_LOG
    try:
        path = mirror_dir() / slug / me / "cccp-debug.log"
        path.parent.mkdir(parents=True, exist_ok=True)
        # One logger per process - the pid suffix avoids handler-doubling if
        # main() is ever entered twice (e.g. in-process tests).
        log = logging.getLogger(f"cccp.{os.getpid()}")
        log.setLevel(logging.DEBUG)
        log.propagate = False
        log.handlers.clear()
        log.filters.clear()
        log.addFilter(_MonoFilter())
        fh = logging.handlers.RotatingFileHandler(
            path, maxBytes=DEBUG_LOG_MAX_BYTES, backupCount=DEBUG_LOG_BACKUPS,
            encoding="utf-8")
        fh.setLevel(logging.DEBUG)
        fh.setFormatter(_KVFormatter())
        log.addHandler(fh)
        _emit_startup_header(log, slug, me, argv)
        return log
    except OSError as e:
        print(f"cccp: debug logging setup failed: {e}", file=sys.stderr)
        return _NULL_LOG


@contextlib.contextmanager
def subcommand_footer(log):
    """Bracket a short-lived subcommand so the log carries a closing line with
    its exit code and user-visible duration. Long-lived `cccp watchtower`
    skips this - its lifecycle is captured by the richer watchtower_stop log
    line instead."""
    start_t = time.monotonic()
    exit_code = 0
    try:
        yield
    except SystemExit as e:
        c = e.code
        exit_code = c if isinstance(c, int) else (0 if c is None else 1)
        raise
    except BaseException:
        exit_code = 1
        raise
    finally:
        dur_ms = (time.monotonic() - start_t) * 1000
        log.debug(f"ev=cccp_end exit={exit_code} duration_ms={dur_ms:.1f}")


# ---------- storage backends ----------

class BlobError(Exception):
    def __init__(self, status, body):
        self.status = status
        self.body = body
        super().__init__(f"blob error {status}: {body[:200]!r}")


class AzureBlobBackend:
    """Minimal Azure Blob REST backend - stdlib urllib plus a container SAS.

    One of the pluggable backends (see BACKENDS). Exposes the small verb set every
    higher-level function calls on its `client` (put_block, get, get_range,
    get_head, ensure_append_blob, append_block, list, delete). Paths are relative
    to the container; the SAS supplies all authentication.
    """

    RETRYABLE = (500, 502, 503, 504)

    def __init__(self, account, container, sas, log=None):
        self.base = f"https://{account}.blob.core.windows.net/{container}"
        self.sas = sas.lstrip("?")
        # The logger is hot-swappable: subcommands construct the client, then
        # assign `client.log = real_log` once setup_logging has chosen a path
        # from the comrade id. The default no-op keeps every `self.log.debug(...)`
        # site safe to call unconditionally.
        self.log = log or _NULL_LOG

    def _url(self, path, query=""):
        u = f"{self.base}/{path}" if path else self.base
        return u + "?" + "&".join(p for p in (query, self.sas) if p)

    def request(self, method, path, query="", data=None, headers=None, retries=3):
        """One REST call. Returns (status, headers_dict, body_bytes).

        Transient 5xx are retried with a short backoff. An HTTPError (4xx) is
        returned, not raised, so callers can branch on expected statuses such as
        the 409 from a conditional create or a 416 past end-of-blob.
        """
        h = {"x-ms-version": API_VERSION}
        if headers:
            h.update(headers)
        url = self._url(path, query)
        # One TimeLogger spans the whole request (all retries); each individual
        # retry attempt emits a point event. NEVER log `url` - it carries the
        # SAS in its query string. `path` is the bare blob path, safe to log.
        with TimeLogger(self.log, "azure_http", method=method, path=path) as t:
            for attempt in range(retries):
                req = urllib.request.Request(url, data=data, method=method, headers=h)
                try:
                    resp = urllib.request.urlopen(req, timeout=30)
                    body = resp.read()
                    t.done(status=resp.status, bytes=len(body), attempts=attempt + 1,
                           date=resp.headers.get("Date"),
                           req_id=resp.headers.get("x-ms-request-id"))
                    return resp.status, dict(resp.headers), body
                except urllib.error.HTTPError as e:
                    if e.code in self.RETRYABLE and attempt < retries - 1:
                        self.log.debug(
                            f"ev=azure_retry method={method} path={_kv(path)} "
                            f"attempt={attempt} status={e.code}")
                        time.sleep(0.5 * (attempt + 1))
                        continue
                    body = e.read()
                    t.done(status=e.code, bytes=len(body), attempts=attempt + 1,
                           date=(e.headers.get("Date") if e.headers else None),
                           req_id=(e.headers.get("x-ms-request-id")
                                   if e.headers else None))
                    return e.code, dict(e.headers), body
                except urllib.error.URLError as e:
                    if attempt < retries - 1:
                        self.log.debug(
                            f"ev=azure_retry method={method} path={_kv(path)} "
                            f"attempt={attempt} url_error={_kv(str(e))}")
                        time.sleep(0.5 * (attempt + 1))
                        continue
                    t.done(url_error=str(e), attempts=attempt + 1)
                    raise

    # -- convenience operations --

    def put_block(self, path, data):
        """PUT a block blob."""
        return self.request("PUT", path, data=data,
                            headers={"x-ms-blob-type": "BlockBlob"})[0]

    def get(self, path):
        st, _, body = self.request("GET", path)
        return st, body

    def get_range(self, path, offset):
        """GET a blob from byte `offset` to the end. Returns (status, body)."""
        st, _, body = self.request("GET", path, headers={"Range": f"bytes={offset}-"})
        return st, body

    def get_head(self, path, nbytes):
        """GET the first `nbytes` of a blob (0..nbytes-1). 206 partial, or 200 if
        the blob is smaller. Used to seed aliases from a gazette's head cheaply."""
        st, _, body = self.request("GET", path,
                                   headers={"Range": f"bytes=0-{nbytes - 1}"})
        return st, body

    def ensure_append_blob(self, path):
        """Create an append blob if absent. 201 created or 409 exists - both fine."""
        return self.request("PUT", path, data=b"",
                            headers={"x-ms-blob-type": "AppendBlob",
                                     "If-None-Match": "*"})[0]

    def append_block(self, path, data):
        """Append bytes to the end of an append blob. Returns (status, offset):
        the byte position the block landed at (x-ms-blob-append-offset), or None
        when the response carries no offset - which a genuine 201 never omits."""
        st, hdrs, _ = self.request("PUT", path, query="comp=appendblock", data=data)
        off = next((v for k, v in hdrs.items()
                    if k.lower() == "x-ms-blob-append-offset"), None)
        return st, (int(off) if off is not None else None)

    def stat(self, path):
        """HEAD a blob. Returns (status, size) - size None unless status 200."""
        st, hdrs, _ = self.request("HEAD", path)
        size = next((v for k, v in hdrs.items()
                     if k.lower() == "content-length"), None)
        return st, (int(size) if st == 200 and size is not None else None)

    def list(self, prefix):
        """List blobs under a prefix, following continuation markers so a cell
        past Azure's 5000-results-per-page cap is still seen whole. Returns
        {name: {"size", "last_modified"}}."""
        out = {}
        marker = ""
        while True:
            query = f"restype=container&comp=list&prefix={urllib.parse.quote(prefix)}"
            if marker:
                query += f"&marker={urllib.parse.quote(marker)}"
            st, _, body = self.request("GET", "", query=query)
            if st != 200:
                raise BlobError(st, body)
            root = ET.fromstring(body)
            for b in root.findall(".//Blob"):
                name = b.findtext("Name")
                props = b.find("Properties")
                size = props.findtext("Content-Length") if props is not None else None
                lm = props.findtext("Last-Modified") if props is not None else None
                out[name] = {"size": int(size) if size else 0, "last_modified": lm}
            marker = root.findtext("NextMarker") or ""
            if not marker:
                return out

    def delete(self, path):
        """DELETE a blob. Returns the status (202 deleted, 404 absent - both fine)."""
        return self.request("DELETE", path)[0]


class LocalFilesBackend:
    """Filesystem backend - the zero-setup default. The store root is a directory
    (backend/local-fs/); blob 'paths' are POSIX-relative names beneath it, so the
    on-disk layout matches the blob backends exactly. Same-host/same-user only:
    writes are plain file writes / O_APPEND, atomic enough for sibling processes
    on one machine (the backend's whole contract) with no locking.

    Returns Azure-shaped status codes so every caller branches identically:
    200/206 reads, 201 writes, 202 delete, 404 absent, 416 past end-of-blob.
    """

    def __init__(self, root, log=None):
        self.root = Path(root)
        self.log = log or _NULL_LOG

    def _abs(self, path):
        return self.root / path

    def put_block(self, path, data):
        p = self._abs(path)
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_bytes(data)
        return 201

    def get(self, path):
        try:
            return 200, self._abs(path).read_bytes()
        except FileNotFoundError:
            return 404, b""

    def get_range(self, path, offset):
        """Bytes from `offset` to end. 206 partial, 200 whole, 416 past EOF, 404 absent."""
        try:
            data = self._abs(path).read_bytes()
        except FileNotFoundError:
            return 404, b""
        if offset and offset >= len(data):
            return 416, b""
        return (206 if offset else 200), data[offset:]

    def get_head(self, path, nbytes):
        """First `nbytes` (0..nbytes-1). 206 if the blob is larger, else 200; 404 absent."""
        try:
            data = self._abs(path).read_bytes()
        except FileNotFoundError:
            return 404, b""
        return (206 if len(data) > nbytes else 200), data[:nbytes]

    def ensure_append_blob(self, path):
        """Create an empty file if absent. 201 created or 409 exists - both fine."""
        p = self._abs(path)
        p.parent.mkdir(parents=True, exist_ok=True)
        try:
            p.touch(exist_ok=False)
            return 201
        except FileExistsError:
            return 409

    def append_block(self, path, data):
        """Append bytes to the end of the file. Returns (201, offset), mirroring
        an Azure appendblock and its x-ms-blob-append-offset."""
        p = self._abs(path)
        p.parent.mkdir(parents=True, exist_ok=True)
        with open(p, "ab") as f:
            off = f.tell()
            f.write(data)
        return 201, off

    def stat(self, path):
        """The file's size. Returns (status, size) - (404, None) when absent."""
        try:
            return 200, self._abs(path).stat().st_size
        except FileNotFoundError:
            return 404, None

    def list(self, prefix):
        """Blobs under `prefix`. Returns {name: {"size", "last_modified"}} with
        names POSIX-relative to the store root (matching the blob backends). cccp
        only ever lists directory prefixes (they end in '/'), so a plain recursive
        walk of the corresponding directory is an exact match."""
        base = self._abs(prefix)
        out = {}
        if not base.is_dir():
            return out
        for p in base.rglob("*"):
            if p.is_file():
                stat = p.stat()
                name = p.relative_to(self.root).as_posix()
                out[name] = {
                    "size": stat.st_size,
                    "last_modified": time.strftime(
                        "%a, %d %b %Y %H:%M:%S GMT", time.gmtime(stat.st_mtime)),
                }
        return out

    def delete(self, path):
        """Remove a file. 202 deleted, 404 absent - both fine."""
        try:
            self._abs(path).unlink()
            return 202
        except FileNotFoundError:
            return 404


def make_backend(cfg, log=None):
    """Construct the active backend from a resolved config. Enforces the
    'never silently downgrade' rule: an explicitly selected backend that is
    missing required params fails loudly here, rather than falling back to
    local-fs. The returned client exposes the shared blob verb set."""
    backend = cfg["BACKEND"]
    params = cfg["PARAMS"]
    if backend == "local-fs":
        root = params.get("root") or backend_dir("local-fs")
        return LocalFilesBackend(Path(root).expanduser(), log=log)
    if backend == "azure-blob":
        missing = [k.upper() for k in ("account", "container", "sas")
                   if not params.get(k)]
        if missing:
            sys.exit(f"error: backend 'azure-blob' is selected but not configured "
                     f"(missing {', '.join(missing)}). Run "
                     f"`cccp config` to inspect or set it up.")
        return AzureBlobBackend(params["account"], params["container"],
                                params["sas"], log=log)
    sys.exit(f"error: unknown backend {backend!r}")


# ---------- cell blob paths ----------

def cell_head(prefix, slug):
    """The blob-name prefix for a cell: '<prefix>/<slug>/', or '<slug>/' when the
    backend uses no prefix (local-fs). Every cell path is built from this, so an
    empty prefix never yields a leading slash or an empty path segment."""
    return f"{prefix}/{slug}/" if prefix else f"{slug}/"


def gazettes_head(prefix, slug):
    """The blob-name prefix holding every gazette in a cell. Gazettes live under
    their own prefix - apart from published files - so the hot path (the
    watchtower's poll LIST, the roster) enumerates one blob per all-time comrade
    and never pays for the cell's accumulated file blobs. 'gazettes' cannot
    collide with a comrade id: ids always carry '@' and ':'."""
    return f"{cell_head(prefix, slug)}gazettes/"


def published_blob(prefix, slug, sender, wire_path):
    """The blob key for a published file: '<cell-head>files/<sender>/<rel>'.
    The wire path keeps its 'files/' prefix (it doubles as the mirror-relative
    path); the blob key groups all publishes under one cell-level files/ area,
    outside the gazettes/ prefix the poll loop lists."""
    rel = wire_path[len("files/"):] if wire_path.startswith("files/") else wire_path
    return f"{cell_head(prefix, slug)}files/{sender}/{rel}"


# ---------- identity & roster ----------

def comrade_id():
    """This session's comrade id: always `user@host:<first-6-of-session-id>`.

    A pure local function - no network, no per-cell claim, no coordination. The
    Claude session UUID is globally unique, so this id is unique by construction:
    `user@host` scopes it to a machine/account, and the 6-char session suffix
    separates sibling Claude sessions on the same host (collision needs two
    siblings whose UUIDs share the first 6 hex - negligible). Every process from
    one session (dispatch, watchtower, skill) computes the identical id with no
    shared state, so they agree for free; that is why claiming is unnecessary.

    CCCP_COMRADE_ID overrides with an explicit id (testing, deliberate control).
    """
    env_id = os.environ.get("CCCP_COMRADE_ID")
    if env_id:
        return env_id
    return f"{base_comrade_id()}:{current_session_id()[:6]}"


def cell_roster(client, prefix, slug):
    """Return the sorted comrade ids registered in a cell. Gazette ownership IS
    registration: every participation event (publish included) appends to the
    sender's gazette, so listing gazettes/ alone sees everyone."""
    head = gazettes_head(prefix, slug)
    comrades = set()
    for name in client.list(head):
        rest = name[len(head):]
        if rest.endswith(".jsonl") and "/" not in rest:
            comrades.add(rest[:-len(".jsonl")])
    return sorted(comrades)


# ---------- journals ----------
#
# An append-only JSONL log read from a byte offset is the one storage pattern
# cccp has: gazettes on the backend (the wire), and the watchtower inbox on local
# disk (see run_dir). Same shape, different scope - so they share this reader
# rather than a second implementation of the accounting, which is where the bugs
# would live.

def journal_records(data, on_bad=None):
    """Parse complete JSON lines out of one read of a journal.

    Returns (records, consumed). `consumed` is how many bytes of `data` are
    accounted for, so a caller tracking an offset advances to offset + consumed.
    A partial trailing line is left UNCONSUMED - the writer is still mid-append,
    so the next read picks that line up whole. An unparseable complete line is
    skipped but still consumed: it can never be repaired, so re-reading it every
    poll forever would be the worse failure. Skipping must not be SILENT though
    (#7: a transport where data loss and a parse bug look identical is
    undebuggable) - `on_bad`, when given, is called with each skipped line.
    """
    records, consumed = [], 0
    for chunk in data.splitlines(keepends=True):
        if not chunk.endswith(b"\n"):
            break   # partial trailing line; pick it up next read
        consumed += len(chunk)
        try:
            records.append(json.loads(chunk))
        except ValueError:
            if on_bad:
                on_bad(chunk)
            continue   # malformed: skipped, but consumed so we never re-read it
    return records, consumed


# ---------- gazette ----------

def gazette_path(prefix, slug, comrade):
    return f"{gazettes_head(prefix, slug)}{comrade}.jsonl"


def append_dispatch(client, prefix, slug, me, dispatch):
    """Append one dispatch (a JSON object) as a line to my gazette append blob,
    then read it back from the store.

    The read-back is the delivery guarantee (#7): exit 0 must mean "the store
    has it", not "the store said yes". A middlebox or store that returns 201
    without persisting is caught here, at send time, instead of surfacing as a
    peer's silence days later. Costs one ranged GET per send."""
    path = gazette_path(prefix, slug, me)
    client.ensure_append_blob(path)
    line = (json.dumps(dispatch, separators=(",", ":")) + "\n").encode("utf-8")
    st, offset = client.append_block(path, line)
    if st != 201:
        raise BlobError(st, b"gazette append failed")
    if offset is None:
        raise BlobError(st, b"gazette append returned no append offset; "
                            b"treat the send as NOT delivered")
    st, tail = client.get_range(path, offset)
    if st not in (200, 206) or not tail.startswith(line):
        raise BlobError(st, b"gazette append read-back failed: the store does "
                            b"not have the line it accepted; the send was "
                            b"NOT delivered")


# ---------- event rendering ----------

def display_path(wire_path):
    """Recover the publisher's original absolute path from the wire path."""
    if wire_path.startswith("files/"):
        return "/" + wire_path[len("files/"):]
    return wire_path


def render_to(to):
    return "*" if to == ["*"] else ",".join(to)


def addressed_to_me(to, me):
    return "*" in to or me in to


def preview_split(body, budget):
    """Longest body prefix whose JSON-escaped inner (no surrounding quotes) fits
    `budget`, without splitting an escape sequence. Returns (inner, n) where inner
    is the escaped preview and n is how many BODY chars it consumed - so the reader
    can be handed exactly body[n:] as the continuation."""
    n, inner = 0, ""
    while n < len(body):
        candidate = json.dumps(body[:n + 1])[1:-1]
        if len(candidate) > budget:
            break
        inner = candidate
        n += 1
    return inner, n


def preview_budget(frm, ts, to, nchars):
    """Per-message preview budget: fill the truncated line up to TRUNCATE_THRESHOLD
    (the Monitor envelope) rather than a fixed amount, so we use whatever room the
    header leaves. Degrades gracefully to 0 with very long headers."""
    fixed = (f"message from={frm} ts={ts} to={to} "
             f"chars={nchars} truncated=true preview=\"\"")
    return max(0, TRUNCATE_THRESHOLD - len(fixed))


def render_overflow_event(d):
    """Compact form when even the truncated line would exceed TRUNCATE_THRESHOLD.
    Replaces the full to-list with a recipient count so the line always fits."""
    n_recip = len(d.get("to") or ["*"])
    body = d.get("body", "")
    return (f"message from={d['from']} ts={d['ts']} "
            f"recipients={n_recip} chars={len(body)} overflow=true")


def render_message_event(d):
    body = d.get("body", "")
    to = render_to(d.get("to", ["*"]))
    full = f"message from={d['from']} ts={d['ts']} to={to} body={json.dumps(body)}"
    if len(full) <= TRUNCATE_THRESHOLD:
        return full
    budget = preview_budget(d["from"], d["ts"], to, len(body))
    preview, _ = preview_split(body, budget)
    truncated = (f"message from={d['from']} ts={d['ts']} to={to} "
                 f"chars={len(body)} truncated=true preview=\"{preview}\"")
    best = truncated if len(truncated) < len(full) else full
    if len(best) <= TRUNCATE_THRESHOLD:
        return best
    return render_overflow_event(d)


def message_read_output(d, full=False):
    """What `cccp read --ts` prints for one message. Default = the body remainder
    PAST the watchtower preview cutoff (with a marker), so the reader doesn't
    re-pay for the prefix it already saw in the event. full=True (or an
    untruncated message) returns the whole body. The split point is recomputed
    from the same preview_budget/preview_split the watchtower used, so it matches
    byte-for-byte - no delivery state is stored."""
    body = d.get("body", "")
    to = render_to(d.get("to", ["*"]))
    full_line = f"message from={d['from']} ts={d['ts']} to={to} body={json.dumps(body)}"
    if full or len(full_line) <= TRUNCATE_THRESHOLD:
        return body
    budget = preview_budget(d["from"], d["ts"], to, len(body))
    preview, n = preview_split(body, budget)
    truncated = (f"message from={d['from']} ts={d['ts']} to={to} "
                 f"chars={len(body)} truncated=true preview=\"{preview}\"")
    best = truncated if len(truncated) < len(full_line) else full_line
    if len(best) > TRUNCATE_THRESHOLD:
        return body
    marker = f"[…from char {n}]"
    return f"{marker}\n{body[n:]}"


def render_filesystem_event(d):
    parts = [f"filesystem from={d['from']} op={d.get('op')} "
             f"path={display_path(d.get('path', ''))}"]
    for k in ("size", "lines", "local"):
        if k in d:
            parts.append(f"{k}={d[k]}")
    parts.append(f"to={render_to(d.get('to', ['*']))}")
    line = " ".join(parts)
    if len(line) <= TRUNCATE_THRESHOLD:
        return line
    n_recip = len(d.get("to") or ["*"])
    overflow = (f"filesystem from={d['from']} op={d.get('op')} "
                f"path={display_path(d.get('path', ''))} "
                f"recipients={n_recip} overflow=true")
    if len(overflow) <= TRUNCATE_THRESHOLD:
        return overflow
    return (f"filesystem from={d['from']} op={d.get('op')} "
            f"recipients={n_recip} overflow=true")


def download_to_mirror(client, prefix, slug, sender, wire_path,
                       expect_size=None, expect_lines=None):
    """Download a published blob into the local mirror; return the local Path.

    Mirror layout is deterministic - <mirror>/<slug>/<sender>/<wire_path>, e.g.
    <mirror>/work-on-cccp/alice@hostA/files/home/alice/build.log - so any follow-up tool
    can read the file by its known path.

    If the publisher's claimed size / line count are given, the downloaded bytes
    are verified against them and a mismatch raises BlobError. This is an
    everybody-trusts-everybody environment, so the check surfaces bugs, not
    attackers.
    """
    st, body = client.get(published_blob(prefix, slug, sender, wire_path))
    if st != 200:
        raise BlobError(st, b"download failed")
    if expect_size is not None and len(body) != expect_size:
        raise BlobError(0, f"{wire_path}: got {len(body)} bytes, "
                           f"publisher claimed {expect_size}".encode())
    if expect_lines is not None and body.count(b"\n") != expect_lines:
        raise BlobError(0, f"{wire_path}: got {body.count(chr(10).encode())} "
                           f"lines, publisher claimed {expect_lines}".encode())
    dest = mirror_dir() / slug / sender / wire_path
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_bytes(body)
    return dest


# ---------- watchtower ----------

def inbox_path(slug, me):
    """This comrade's watchtower inbox for one cell: a local, private, append-only
    journal of commands for the live watchtower (`{"ev": ...}` per line).

    One watchtower = one cell = one comrade, so the path IS the scope of what it
    carries - a broadcast signal needs no addressing because each watchtower only
    ever opens its own. Deliberately local and never routed through the backend:
    a command to a local process must not cost a network round-trip, must not be
    unsendable when the backend is down, and is nobody else's business.
    """
    return run_dir() / "watchtower" / slug / me / "inbox.jsonl"


def pid_path(slug, me):
    """The live watchtower's pid record (JSON: pid, started), written at startup
    and removed on any clean exit - so a pidfile with no matching process means
    exactly "died without running its exit path" (#18). Scoped like the inbox:
    one watchtower = one cell = one comrade."""
    return run_dir() / "watchtower" / slug / me / "pid.json"


def last_stop_path(slug, me):
    """The most recent clean stop (JSON: ts, reason, pid), written by the exit
    path pid_path's removal happens in. Survives until read; `cccp status` is
    the reader. Never cleaned up - each stop overwrites the last."""
    return run_dir() / "watchtower" / slug / me / "last-stop.json"


def process_argv(pid):
    """The command line of a live process, or None when no such process. Uses ps
    (portable across Linux and macOS; /proc is not)."""
    if not isinstance(pid, int) or pid <= 0:
        return None
    r = subprocess.run(["ps", "-o", "args=", "-p", str(pid)],
                       capture_output=True, text=True)
    if r.returncode != 0:
        return None
    return r.stdout.strip() or None


def watchtower_status(slug, me):
    """(state, human line) for my watchtower in one cell.

    States: "alive" (pid record's process exists AND its argv carries both this
    cell and my ownership tag - a recycled pid cannot fake that), "stale"
    (pid record but no such watchtower: it died hard, nothing ran its exit
    path), "stopped" (clean exit, reason recorded), "absent" (no record at
    all). #18: a dead watchtower must be distinguishable from a quiet cell in
    one command."""
    try:
        rec = json.loads(pid_path(slug, me).read_text())
    except (OSError, ValueError):
        rec = None
    if rec:
        pid = rec.get("pid")
        argv = process_argv(pid)
        if argv and f"cccp watchtower {slug} " in argv \
                and argv.endswith(f"-- {me}"):
            return "alive", f"alive pid={pid} started={rec.get('started', '?')}"
        return "stale", (f"dead pid={pid}: pid record is stale - the "
                         f"watchtower died without a clean exit (killed or "
                         f"crashed hard), so no stop reason was recorded")
    try:
        stop = json.loads(last_stop_path(slug, me).read_text())
        return "stopped", (f"stopped reason={stop.get('reason', '?')} "
                           f"at={stop.get('ts', '?')}")
    except (OSError, ValueError):
        return "absent", f"no watchtower record for cell {slug!r}"


def inbox_send(slug, me, records):
    """Append command records to my own watchtower's inbox, then wake it.

    One complete JSON line each, O_APPEND, written in a single call - the same
    atomicity bet the local-fs backend already makes for gazettes, and it keeps a
    batch in order without the reader needing to know a batch happened.

    The wake is what makes this prompt: SIGUSR1 means only "poll now", and a poll
    drains the inbox first, so the record lands within ms instead of at the next
    rung of the ladder."""
    path = inbox_path(slug, me)
    path.parent.mkdir(parents=True, exist_ok=True)
    blob = b"".join((json.dumps(r, separators=(",", ":")) + "\n").encode("utf-8")
                    for r in records)
    with open(path, "ab") as f:
        f.write(blob)
    return wake_watchtowers(slug)


def wake_pattern(slug):
    """The pkill -f ERE matching ONLY live watchtower processes for `slug` -
    never the Monitor bash wrapper that carries the same words quoted inside
    its own cmdline. Getting this wrong is fatal, not cosmetic: SIGUSR1's
    default disposition is Term, so a matched wrapper DIES and its watchtower
    follows via the ppid watchdog.

    The anchor is the ps ownership tag (cmd_watchtower's re-exec): a real
    watchtower's cmdline always ENDS with `-- <comrade-id>`, while the
    wrapper's continues past the quoted command into harness plumbing. The
    previous anchor - "a quote follows the slug in the wrapper" - held only
    for flag-less arming: with flags (e.g. --alias-trigger) a SPACE follows
    the slug in the wrapper too, so every wake/deadline-arm broadcast beheaded
    any same-cell watchtower armed with flags, wrapper first (the #5 churn).

    The trailing space after the slug also keeps `foo` from matching
    `foo-bar`. POSIX ERE only (BSD pkill on macOS, procps on Linux): [^ ]
    instead of \\S, literal alternations, no PCRE."""
    return rf"cccp watchtower {re.escape(slug)} (.* )?-- [^ ]+$"


def wake_watchtowers(slug):
    """SIGUSR1 every local watchtower for `slug` - "poll now". Returns the completed
    pkill process: rc 0 = at least one signalled, 1 = none running (which is NOT an
    error - an inbox record simply waits for a watchtower that may never come).

    Shared by `cccp wake` and by anything that drops a record in an inbox. See
    cmd_wake for the sibling-session caveat."""
    return subprocess.run(["pkill", "-USR1", "-f", wake_pattern(slug)],
                          capture_output=True)


# ---------- aliases (opt-in, view-layer) ----------
#
# Aliases are human/LLM-friendly names for comrades, kept as a LOCAL projection:
# the wire and the data model always carry raw user@host:hex ids. A comrade
# declares its alias in an intro whose body starts with the watchtower's
# --alias-trigger prefix; every armed comrade - including the declarer's own
# watchtower, which reads its own gazette for exactly this - learns it and
# translates on the way in (watchtower metadata) and out (dispatch --to). Off
# entirely unless a trigger is set, so bare `chat` is unchanged; `team` is the
# layer that turns it on.

ALIAS_TOKEN = re.compile(r"[A-Za-z0-9][A-Za-z0-9_-]*")   # a shell-safe alias
ALIAS_SEED_BYTES = 64 * 1024   # per-gazette cap when seeding the map at startup.
                               # The declaring intro sits at a gazette's START, so
                               # a small head read finds it without scanning a
                               # months-long history.
ALIAS_SEED_MAX_AGE_SECONDS = 7 * 24 * 3600   # skip seeding from gazettes idle
                               # longer than this: an old cell accumulates
                               # gazettes from long-gone comrades forever (there
                               # is no per-comrade cleanup), and each costs a
                               # head read at startup. A quiet-but-present
                               # comrade skipped here renders as a raw id until
                               # it next speaks, when live learning re-acquires
                               # the alias - so the cutoff errs generous.


def is_comrade_id(s):
    """A comrade id always carries both '@' and ':'; a shell-safe alias never does.
    That makes the two unambiguous - which is what lets `alias` set/show take the
    id and the name in either order, and lets --to tell an alias from an id."""
    return "@" in s and ":" in s


def alias_map_path(slug, me):
    return mirror_dir() / slug / me / "aliases.json"


def load_aliases(slug, me):
    """The local {comrade_id: alias} map for this cell. Missing/corrupt -> {}."""
    try:
        data = json.loads(alias_map_path(slug, me).read_text())
        return data if isinstance(data, dict) else {}
    except (OSError, ValueError):
        return {}


def save_aliases(slug, me, amap):
    path = alias_map_path(slug, me)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(amap, sort_keys=True))


def parse_alias(body, trigger):
    """If `body` starts with `trigger`, return the first shell-safe token after it,
    else None. The alias is a single token, so parsing can never over-read.

    Two mis-parse classes are rejected (the `I`/`omni` garbage of issue #1): a
    token continuing into '@' or ':' is the start of a comrade id, not a name;
    and a single-char token is prose ("Intro: I am..."), so names are >= 2 chars."""
    if not trigger or not body.startswith(trigger):
        return None
    rest = body[len(trigger):].lstrip()
    m = ALIAS_TOKEN.match(rest)
    if not m or len(m.group(0)) < 2 or rest[m.end():m.end() + 1] in ("@", ":"):
        return None
    return m.group(0)


def learn_alias(amap, cid, alias):
    """Apply a declaration to `amap` (mutated in place); return a one-line info
    event describing the change, or None if nothing changed. A name maps to exactly
    one id (last-writer-wins), so three cases arise:
      new      - cid had no alias and the name was free
      rename   - cid already had a different alias (same comrade, new name)
      reassign - the name was held by a different id (a handoff/succession)"""
    if amap.get(cid) == alias:
        return None
    prev_holder = next((i for i, a in amap.items() if a == alias and i != cid), None)
    old_alias = amap.get(cid)
    amap[cid] = alias
    if prev_holder is not None:
        del amap[prev_holder]      # the name moves; one name -> one id
        return f"alias name={alias} id={cid} was_id={prev_holder} kind=reassign"
    if old_alias is not None:
        return f"alias name={alias} id={cid} was={old_alias} kind=rename"
    return f"alias name={alias} id={cid} kind=new"


def alias_or_id(amap, me, cid):
    """How a comrade id renders in event metadata: 'you' for self, the alias if
    known, else the raw id unchanged."""
    if cid == me:
        return "you"
    return amap.get(cid, cid)


def resolve_recipient(amap, token):
    """Map a --to token to a comrade id: an id or '*' passes through; an alias is
    looked up. Returns (id_or_None, error_or_None)."""
    if token == "*" or is_comrade_id(token):
        return token, None
    for cid, alias in amap.items():
        if alias == token:
            return cid, None
    return None, f"unknown alias {token!r}"


class Watchtower:
    """Polls the cell prefix and emits one event line per new dispatch. A live-
    event stream: it skips backlog at startup (no replay). The only local state is
    an optional, opt-in alias map (--alias-trigger); identity and history otherwise
    live in the container."""

    def __init__(self, client, prefix, slug, me, idle_initial,
                 idle_max=IDLE_MAX_SECONDS, log=None, quiet=(), trigger=None,
                 autodownload_max=None):
        self.client = client
        self.prefix = prefix
        self.slug = slug
        self.autodownload_max = (autodownload_max if autodownload_max is not None
                                 else parse_size(AUTODOWNLOAD_MAX_DEFAULT))
        self.me = me
        # Alias support is opt-in: with no --alias-trigger, `self.trigger` is None
        # and the whole feature is inert (no seed, no learn, no translation).
        self.trigger = trigger
        self.aliases = {}   # comrade_id -> alias; reloaded from disk each poll
        self.quiet = set(quiet)   # event types to handle but not emit (e.g. a
                                  # coordination hub suppresses 'filesystem' - the
                                  # file still auto-downloads, just no notify turn)
        self.hwm = {}        # comrade -> bytes consumed of their gazette
        # Bytes consumed of my own inbox (see inbox_path). In memory only, never
        # persisted: commands are for a live watchtower, so a new one starts from
        # a truncated file with nothing to restore.
        self.inbox_offset = 0
        # Armed response deadlines: comrade -> {expiry (monotonic), limit_s,
        # limit (as typed), sent (iso)}. In memory only and never persisted, so a
        # watchtower's death takes its timers with it - a missed alert, which is
        # the safe direction, rather than a false one fired by a successor.
        self.deadlines = {}
        self.stop = False
        self.stop_reason = None
        # Whoever launched us (the Monitor bash wrapper). A watchtower must never
        # outlive its creator: once this changes we have been re-parented, our
        # stdout reader is gone, and every event we emit is unread.
        self.ppid = os.getppid()
        self.log = log or _NULL_LOG
        # Idle backoff: start at idle_initial, double after each idle emission up
        # to idle_max, reset to idle_initial on any activity. idle_initial=0
        # disables idle events entirely.
        self.idle_initial = idle_initial
        self.idle_max = idle_max
        self.idle_current = idle_initial
        self.last_activity = time.monotonic()
        self.idle_due = self.last_activity + idle_initial
        # Adaptive poll cadence: ladder_step is the next index into POLL_LADDER;
        # -1 means "the next poll is the first since reset" so _next_sleep will
        # pre-increment to 0 and return LADDER[0] (the fast cadence). Any real
        # event or SIGUSR1 sets ladder_step back to -1. _interrupt breaks the
        # inter-poll sleep so SIGTERM/SIGINT/SIGUSR1 take effect within ms even
        # mid-60s gap.
        self.ladder_step = -1
        self._interrupt = threading.Event()
        self.wake_requested = False

    def _log(self, msg):
        """Append timestamped diagnostics to a per-cell watchtower log. MUST NEVER
        raise -- it is the last-resort record for when stdout/stderr are themselves
        broken (#503 instrumentation): a captured traceback here turns the next
        crash from inference into proof. This is distinct from self.log (the opt-in
        CCCP_DEBUG logger); _log is always on and never depends on config."""
        try:
            path = mirror_dir() / self.slug / "watchtower.log"
            path.parent.mkdir(parents=True, exist_ok=True)
            with open(path, "a") as f:
                f.write(f"{now_iso()} {msg}\n")
        except Exception:
            pass

    def _emit(self, line):
        if len(line) > TRUNCATE_THRESHOLD:
            line = line[:TRUNCATE_THRESHOLD - 14] + " overflow=true"
        try:
            print(line, flush=True)
        except BrokenPipeError as e:
            # Our stdout reader is gone - no Monitor, no Claude, and nothing will
            # ever see another event. That is proof we have no purpose, not a
            # fault to survive: stop. (Python ignores SIGPIPE, so a dead pipe
            # raises here instead of killing us.) The _log call stays - it is the
            # record of WHY we stopped, which is what the #503 catch wanted.
            self._log(f"_emit stdout closed ({type(e).__name__}: {e}); stopping; "
                      f"line skipped: {line[:120]!r}")
            self.stop = True
            self.stop_reason = "stdout_closed"
            # Python flushes stdout once more at interpreter exit; on a dead pipe
            # that re-raises and prints "Exception ignored ... BrokenPipeError" to
            # stderr. Point stdout at devnull so the final flush is a no-op and
            # this stays a clean, deliberate exit.
            try:
                os.dup2(os.open(os.devnull, os.O_WRONLY), sys.stdout.fileno())
            except OSError:
                pass
        except OSError as e:
            self._log(f"_emit failed ({type(e).__name__}: {e}); line skipped: {line[:120]!r}")

    @staticmethod
    def _format_quiet(seconds):
        """Compact label for the elapsed silence on an idle event - minutes up to
        the hour, then hours. Keeps `quiet=24h` from rendering as `quiet=1440m`."""
        minutes = round(seconds / 60)
        if minutes < 60:
            return f"{minutes}m"
        return f"{round(minutes / 60)}h"

    def _next_sleep(self):
        """Advance one rung up the ladder (capped) and return the gap before the
        next poll. Reset (ladder_step = -1) on any activity or SIGUSR1 wake."""
        self.ladder_step = min(self.ladder_step + 1, len(POLL_LADDER) - 1)
        gap = POLL_LADDER[self.ladder_step]
        # Never sleep THROUGH an armed deadline. The ladder still climbs normally;
        # only the one sleep that would overrun an expiry gets shortened, so idle
        # backoff is untouched and no minimum deadline is needed - a 180s deadline
        # on a cell polling every 300s still fires at 180s.
        clamped = None
        if self.deadlines:
            soonest = min(d["expiry"] for d in self.deadlines.values())
            clamped = max(0.0, soonest - time.monotonic())
            gap = min(gap, clamped)
        self.log.debug(
            f"ev=sleep ladder_step={self.ladder_step} cadence_s={gap:.1f}"
            + (f" deadline_clamp_s={clamped:.1f}" if clamped is not None else ""))
        return gap

    def _scan(self):
        """List the cell's gazettes: comrade -> {"size", "last_modified"}. Lists
        only the gazettes/ prefix, so the cost is one blob per all-time comrade
        regardless of how many files the cell has accumulated."""
        with TimeLogger(self.log, "scan") as t:
            gazettes = {}
            head = gazettes_head(self.prefix, self.slug)
            blobs = self.client.list(head)
            for name, props in blobs.items():
                rest = name[len(head):]
                if rest.endswith(".jsonl") and "/" not in rest:
                    gazettes[rest[:-len(".jsonl")]] = props
            t.done(blobs=len(blobs), gazettes=len(gazettes))
            return gazettes

    def initial_scan(self):
        """Fast-forward HWMs to skip existing backlog (no replay)."""
        gazettes = self._scan()
        for comrade, props in gazettes.items():
            self.hwm[comrade] = props["size"]

    def seed_aliases(self):
        """Build the baseline alias map from each gazette's HEAD (capped at
        ALIAS_SEED_BYTES) SILENTLY - the startup baseline emits no events; only
        live changes do. Declarations are applied oldest-first so last-writer-wins
        holds within the seeded window."""
        amap = load_aliases(self.slug, self.me)
        decls = []   # (ts, from_id, alias)
        cutoff = (datetime.now(timezone.utc)
                  - timedelta(seconds=ALIAS_SEED_MAX_AGE_SECONDS))
        stale = 0
        # My own gazette is included: my intro lands there and nowhere else, so
        # skipping self would resurrect a dead predecessor's mapping from backlog
        # while my own could never be seeded at all (issue #1).
        for comrade, props in self._scan().items():
            # A gazette is append-only, so last_modified is the comrade's last
            # word; older than the cutoff means long departed (or long quiet -
            # live learning recovers those). Absent/unparseable stays seeded:
            # a missing timestamp must not cost anyone their alias.
            lm = props.get("last_modified")
            if lm:
                try:
                    if email.utils.parsedate_to_datetime(lm) < cutoff:
                        stale += 1
                        continue
                except (TypeError, ValueError):
                    pass
            st, data = self.client.get_head(
                gazette_path(self.prefix, self.slug, comrade), ALIAS_SEED_BYTES)
            if st not in (200, 206):
                continue
            for chunk in data.splitlines():
                try:
                    dd = json.loads(chunk)
                except ValueError:
                    continue   # a byte-capped head can end mid-line - skip it
                if dd.get("type") != "message":
                    continue
                name = parse_alias(dd.get("body", ""), self.trigger)
                if name and dd.get("from"):
                    decls.append((dd.get("ts", ""), dd["from"], name))
        for _ts, cid, name in sorted(decls, key=lambda x: x[0]):
            learn_alias(amap, cid, name)   # silent: discard the event line
        save_aliases(self.slug, self.me, amap)
        self.aliases = amap
        self.log.debug(f"ev=aliases_seeded count={len(amap)} stale_skipped={stale}")

    def run(self):
        self._reset_inbox()
        self._write_pidfile()
        try:
            self._run()
        finally:
            self._record_stop()

    def _write_pidfile(self):
        """Liveness record for `cccp status` (#18). Best-effort: a watchtower
        that cannot write it still serves events."""
        try:
            p = pid_path(self.slug, self.me)
            p.parent.mkdir(parents=True, exist_ok=True)
            p.write_text(json.dumps({"pid": os.getpid(), "started": now_iso()}))
        except OSError as e:
            self._log(f"pidfile write failed ({type(e).__name__}: {e})")

    def _record_stop(self):
        """Make the death visible (#18): a final `shutdown` event while stdout
        may still work, the reason persisted for `cccp status`, and the pidfile
        cleared - so a pidfile that outlives us means exactly "died hard".
        stdout_closed is the one reason that cannot be emitted (the reader is
        what died); it is still recorded."""
        exc = sys.exc_info()[1]
        reason = self.stop_reason or (
            f"crash_{type(exc).__name__}" if exc else "unknown")
        if reason != "stdout_closed":
            self._emit(f"shutdown {self.me} slug={self.slug} reason={reason}")
        self._log(f"stopped reason={reason}")
        self.log.debug(f"ev=watchtower_stop reason={_kv(reason)}")
        try:
            last_stop_path(self.slug, self.me).write_text(json.dumps(
                {"ts": now_iso(), "reason": reason, "pid": os.getpid()}))
            pid_path(self.slug, self.me).unlink(missing_ok=True)
        except OSError as e:
            self._log(f"stop record write failed ({type(e).__name__}: {e})")

    def _run(self):
        with TimeLogger(self.log, "initial_scan"):
            self.initial_scan()
        if self.trigger:
            with TimeLogger(self.log, "seed_aliases"):
                self.seed_aliases()
        self._emit(f"ready {self.me} slug={self.slug} v={CCCP_VERSION}")
        self.log.debug(
            f"ev=watchtower_ready comrade={_kv(self.me)} slug={_kv(self.slug)} "
            f"idle_initial_s={self.idle_initial} idle_max_s={self.idle_max} "
            f"gazettes={len(self.hwm)}")
        # Start the idle clock from "fully up", after the network-bound startup.
        self.last_activity = time.monotonic()
        self.idle_current = self.idle_initial
        self.idle_due = self.last_activity + self.idle_initial
        self.ladder_step = -1
        signal.signal(signal.SIGTERM, self._on_signal)
        signal.signal(signal.SIGINT, self._on_signal)
        signal.signal(signal.SIGUSR1, self._on_wake)
        while not self.stop:
            # Never outlive our creator. A changed ppid means the parent exited
            # and we were re-parented, so nobody is reading stdout any more.
            # Compare against the ORIGINAL ppid, never against 1: a subreaper
            # (`systemd --user`) adopts orphans instead of init, which is exactly
            # what #1 observed. Checked before the poll so a dead reader costs no
            # network I/O.
            if os.getppid() != self.ppid:
                self._log(f"parent exited (ppid {self.ppid} -> {os.getppid()}); stopping")
                self.stop_reason = "parent_exited"
                break
            try:
                with TimeLogger(self.log, "poll"):
                    self._poll_once()
            except Exception as e:
                print(f"watchtower error: {e}", file=sys.stderr)
                self.log.debug(
                    f"ev=watchtower_error exc={type(e).__name__} "
                    f"msg={_kv(str(e))}")
                # Last-resort always-on record (#503): a poll fault must not kill
                # the loop. Capture the traceback so the next crash is proof.
                self._log("poll_once exception (survived):\n" + traceback.format_exc())
            if self.stop:
                break
            # Event.wait so SIGTERM/SIGINT/SIGUSR1 can break the sleep promptly;
            # Python 3 time.sleep is not interruptible by signals (PEP 475).
            # Wrapped so a fault in the sleep/wake path can't silently kill the
            # loop either (#503 belt), with a fallback sleep so a raising
            # _next_sleep/wait can never spin a busy-loop.
            try:
                if self._interrupt.wait(timeout=self._next_sleep()):
                    self._interrupt.clear()
                    if self.wake_requested:
                        self.wake_requested = False
                        self.last_activity = time.monotonic()
                        self.ladder_step = -1
                        # Log in the main loop, not in the signal handler -
                        # `logging` takes a lock and is not async-signal-safe.
                        self.log.debug("ev=wake_received")
            except Exception:
                self._log("sleep/wake exception (survived):\n" + traceback.format_exc())
                time.sleep(POLL_LADDER[-1])

    def _on_signal(self, signum, _frame):
        self.stop = True
        self.stop_reason = f"signal_{signum}"
        self._interrupt.set()

    def _on_wake(self, *_):
        self.wake_requested = True
        self._interrupt.set()

    def _reset_inbox(self):
        """Start from an empty inbox. Commands address a specific live watchtower,
        so anything a previous one left behind is meaningless. Truncate-on-start
        is simultaneously this file's GC - nothing else ever cleans it up, and
        nothing has to: no cleanup phase, no enumeration, no stale-state sweep."""
        path = inbox_path(self.slug, self.me)
        try:
            path.parent.mkdir(parents=True, exist_ok=True)
            with open(path, "wb"):
                pass
        except OSError as e:
            self._log(f"inbox reset failed ({type(e).__name__}: {e})")
        self.inbox_offset = 0

    def _drain_inbox(self):
        """Apply commands appended to my inbox since the last drain.

        Runs first in every poll, and SIGUSR1 already means "poll now" - so a
        writer appends, signals, and lands within ms, with no signal machinery of
        its own. Costs a stat and an early-out in the overwhelmingly common case
        where nothing has been written."""
        path = inbox_path(self.slug, self.me)
        try:
            size = path.stat().st_size
        except OSError:
            return   # no inbox yet: nobody has ever sent us a command
        if size <= self.inbox_offset:
            return   # nothing new
        try:
            with open(path, "rb") as f:
                f.seek(self.inbox_offset)
                data = f.read()
        except OSError as e:
            self._log(f"inbox read failed ({type(e).__name__}: {e})")
            return
        records, consumed = journal_records(
            data, on_bad=lambda c: self._log(f"skip unparseable inbox line: {c[:120]!r}"))
        self.inbox_offset += consumed
        self.log.debug(
            f"ev=inbox_drained records={len(records)} bytes={consumed} "
            f"offset={self.inbox_offset}")
        for rec in records:
            self._apply_inbox(rec)

    def _apply_inbox(self, rec):
        """Dispatch one inbox command. An unrecognized `ev` is ignored, exactly as
        the gazette ignores an unrecognized `type` - so a newer writer can never
        break an older watchtower."""
        ev = rec.get("ev")
        if ev == "ping":
            self._log(f"inbox ping: {rec!r}")
            return
        if ev == "deadline":
            self._arm_deadline(rec)
            return
        if ev == "shutdown":
            # Deliberate, kill-free termination (#16): the inbox is keyed
            # (cell, comrade), so only this comrade's own tooling can reach us -
            # a shutdown can never arrive from a peer's recovery routine. The
            # final `shutdown` event is emitted by _record_stop with this
            # reason, exactly like every other stop path.
            self._log(f"inbox shutdown: {rec!r}")
            self.stop = True
            self.stop_reason = "inbox_shutdown"
            return
        self.log.debug(f"ev=inbox_unknown rec={_kv(json.dumps(rec))}")

    def _arm_deadline(self, rec):
        """Arm (or clear, on limit=null) one comrade's response deadline. One verb
        - set(comrade, limit-or-null) - so last-writer-wins falls out of replay
        order with no dedup pass, and at most one timer per comrade holds by
        construction."""
        to = rec.get("to")
        if not to:
            return
        limit = rec.get("limit")
        if limit is None:
            if self.deadlines.pop(to, None) is not None:
                self.log.debug(f"ev=deadline_disarmed comrade={_kv(to)}")
            return
        limit_s = parse_duration(limit)
        if limit_s is None:
            self.log.debug(f"ev=deadline_bad rec={_kv(json.dumps(rec))}")
            return
        # Anchor on the record's `ts` (our own message's, written by dispatch on
        # this same host and therefore this same clock) rather than on arrival:
        # subtracting the record's age keeps a late drain - a lost signal, a slow
        # poll - from silently granting the comrade extra time. Absent for a
        # bodyless arm, which was written milliseconds ago anyway.
        age = 0.0
        try:
            sent_dt = datetime.strptime(
                rec["ts"], "%Y-%m-%dT%H:%M:%S.%fZ").replace(tzinfo=timezone.utc)
            age = max(0.0, (datetime.now(timezone.utc) - sent_dt).total_seconds())
        except (KeyError, TypeError, ValueError):
            pass
        self.deadlines[to] = {
            "expiry": time.monotonic() + max(0.0, limit_s - age),
            "limit_s": limit_s,
            "limit": limit,
            "ts": rec.get("ts"),   # the awaited message's id; None if armed bare
            # A standing deadline re-arms instead of disarming, on both a reply and
            # a miss - a cadence, not a one-shot.
            "standing": bool(rec.get("standing")),
        }
        self.log.debug(
            f"ev=deadline_armed comrade={_kv(to)} limit={limit} age_s={age:.1f} "
            f"standing={bool(rec.get('standing'))}")

    def _rearm(self, d):
        """Restart a standing timer for another full `limit` from now. Deliberately
        flat - no backoff. The idle heartbeat backs off because it is unsolicited
        nagging; a standing deadline was explicitly asked for, and a comrade that
        has stopped reporting should stay just as loud on the tenth miss as the
        first. `ts` is kept across re-arms: it identifies the message that
        established the expectation, which is exactly what a later miss is about."""
        d["expiry"] = time.monotonic() + d["limit_s"]

    def _met_deadline(self, comrade):
        """A message from `comrade` beat their deadline: disarm it and describe the
        outcome, or None if none was armed.

        Both endpoints are the LOCAL clock (monotonic elapsed since arming, plus
        the record's age at arm time), deliberately not the message's `ts` - that
        is the sender's clock on another host, and cross-comrade skew is a known
        real effect here (see the lag_ms note in _poll_once). "How long between my
        dispatch and my seeing the reply" needs no skew correction."""
        d = self.deadlines.get(comrade)
        if d is None:
            return None
        early = max(0.0, d["expiry"] - time.monotonic())
        took = max(0.0, d["limit_s"] - early)
        line = (self._deadline_head(comrade, d, "met")
                + f" took={format_duration(took)} early={format_duration(early)}")
        # A standing timer re-arms here silently: the met line already says they
        # reported, and `standing=true` on it says another window has begun. The
        # healthy case must not cost a second event.
        if d["standing"]:
            self._rearm(d)
        else:
            del self.deadlines[comrade]
        return line

    def _deadline_head(self, comrade, d, result):
        """The fields a met and a missed event share, in the same order - so a
        missed line is exactly a met line stopped early, and `result=` states the
        outcome outright instead of leaving it to be inferred from which fields
        happen to be present. `standing=` sits next to `result=` because it
        qualifies it: whether this outcome is the end of the matter or one window
        of a cadence. Emitted only when true; absent means a one-shot."""
        name = alias_or_id(self.aliases, self.me, comrade)
        # A stale alias map can name the WRONG comrade (#13) - whenever the
        # rendered name is not the id itself, the id rides along so the event
        # stays attributable no matter what the map thinks.
        ident = f" id={comrade}" if name != comrade else ""
        standing = " standing=true" if d.get("standing") else ""
        ts = f" ts={d['ts']}" if d.get("ts") else ""
        return (f"deadline comrade={name}{ident} result={result}{standing}{ts} "
                f"limit={d['limit']}")

    def _expire_deadlines(self):
        """Alert on every deadline that has passed, and disarm it. Called AFTER
        gazette processing in a poll: a reply landing at the wire clears its timer
        in the same poll that would otherwise have fired it, so polling-before-
        firing actually prevents the spurious alert rather than merely timing it
        well. Returns how many fired."""
        now = time.monotonic()
        due = [c for c, d in self.deadlines.items() if d["expiry"] <= now]
        for comrade in due:
            d = self.deadlines[comrade]
            self._emit(self._deadline_head(comrade, d, "missed"))
            self.log.debug(f"ev=deadline_expired comrade={_kv(comrade)} "
                           f"limit={d['limit']} standing={d['standing']}")
            if d["standing"]:
                self._rearm(d)   # alert again on the same cadence until they report
            else:
                del self.deadlines[comrade]
        return len(due)

    def _poll_once(self):
        self._drain_inbox()
        if self.stop:
            return   # an inbox shutdown ends the poll before any network I/O
        gazettes = self._scan()
        messages = []   # (ts, line)
        # Reload the alias map from disk each poll so manual `cccp alias` edits
        # (written by a separate process) are picked up; live learnings merge in.
        if self.trigger:
            self.aliases = load_aliases(self.slug, self.me)
        alias_dirty = False

        for comrade, props in gazettes.items():
            # My own gazette is read for alias learning ONLY - my intro lands
            # there and nowhere else, so an armed watchtower that skips self can
            # never register its own alias (issue #1). Unarmed, self is skipped
            # whole; either way my own dispatches never echo back as events.
            is_me = comrade == self.me
            if is_me and not self.trigger:
                continue
            offset = self.hwm.get(comrade, 0)
            if props["size"] <= offset:
                continue
            st, data = self.client.get_range(
                gazette_path(self.prefix, self.slug, comrade), offset)
            if st not in (200, 206):
                continue
            records, consumed = journal_records(
                data, on_bad=lambda c, who=comrade: self._log(
                    f"skip unparseable gazette line from {who}: {c[:120]!r}"))
            for d in records:
                # Learn aliases from every visible message (not just those
                # addressed to me - intros broadcast), before the render filter.
                if self.trigger and d.get("type") == "message":
                    name = parse_alias(d.get("body", ""), self.trigger)
                    if name and d.get("from"):
                        ev = learn_alias(self.aliases, d["from"], name)
                        if ev:
                            alias_dirty = True
                            messages.append((d.get("ts", now_iso()), ev))
                if is_me:
                    continue   # learn-only: no echo, no deadline credit
                # Any message from this comrade proves they are alive and answering,
                # so it clears their deadline - even one addressed elsewhere, and
                # even one _render filtered out.
                #
                # Its own line rather than appended to the message event, because
                # `cccp read --ts` recomputes the preview cutoff from preview_budget
                # WITHOUT knowing about deadlines: widening that header would desync
                # the split and silently swallow body chars (see #8). Emitted just
                # BEFORE its message so the reader gets the context ("this is the
                # reply I was waiting on") before the content. Both land in the same
                # _emit loop, and Monitor batches stdout within 200ms, so this is one
                # notification of two lines - not two turns. Equal `ts` plus a stable
                # sort keeps them adjacent and in this order.
                met = (self._met_deadline(comrade)
                       if d.get("type") == "message" else None)
                if met:
                    messages.append((d.get("ts", now_iso()), met))
                line = self._render(d)
                if line:
                    messages.append((d.get("ts", now_iso()), line))
            self.hwm[comrade] = offset + consumed

        if alias_dirty:
            save_aliases(self.slug, self.me, self.aliases)
        messages.sort(key=lambda x: x[0])
        for ts_str, line in messages:
            self._emit(line)
            # lag_ms = how far the message's stated `ts` is behind the wall
            # clock right now - this comrade's local view of end-to-end latency
            # from sender's gazette append to local detection + emit. Cross-
            # comrade comparison anchors on the Azure `Date` header logged on
            # every azure_http line to correct for clock skew.
            lag_ms = None
            try:
                ts_dt = datetime.strptime(
                    ts_str, "%Y-%m-%dT%H:%M:%S.%fZ").replace(tzinfo=timezone.utc)
                lag_ms = (datetime.now(timezone.utc) - ts_dt).total_seconds() * 1000
            except (ValueError, TypeError):
                pass
            self.log.debug(
                f"ev=event_emitted kind=message ts={ts_str} "
                f"lag_ms={lag_ms if lag_ms is None else f'{lag_ms:.1f}'}")

        # Idle heartbeat: reassure Claude that a quiet line is healthy, not dead.
        # Local watchtower→Claude only — there is deliberately no inter-comrade
        # heartbeat. The cell model is async/durable (like Slack): a quiet comrade
        # is quiet, not broken, and a dispatch to it waits in the container.
        # Backoff: each idle emission doubles the interval (capped at idle_max),
        # so a long-silent cell stops nagging Claude. Activity resets to initial.
        # Strictly after the gazette pass, so a reply at the wire disarms its timer
        # before this could fire on it.
        expired = self._expire_deadlines()

        now = time.monotonic()
        if messages or expired:
            self.last_activity = now
            self.idle_current = self.idle_initial
            self.idle_due = now + self.idle_initial
            self.ladder_step = -1     # back to fast poll on any real event
        elif self.idle_initial > 0 and now >= self.idle_due:
            quiet_label = self._format_quiet(now - self.last_activity)
            self._emit(f"idle quiet={quiet_label}")
            next_idle = min(self.idle_current * 2, self.idle_max)
            self.log.debug(
                f"ev=idle_emitted quiet={quiet_label} "
                f"idle_current_s={self.idle_current} next_idle_s={next_idle}")
            self.idle_current = next_idle
            self.idle_due = now + self.idle_current

    def _aliased(self, d):
        """A copy of `d` with `from`/`to` ids rendered as aliases (metadata only,
        never the body). A no-op when aliases are off/empty. Called AFTER the
        addressed-to-me check and any side effects, which use the raw ids."""
        if not self.aliases:
            return d
        out = dict(d)
        if out.get("from") is not None:
            out["from"] = alias_or_id(self.aliases, self.me, out["from"])
        out["to"] = [alias_or_id(self.aliases, self.me, x)
                     for x in (d.get("to") or ["*"])]
        return out

    def _render(self, d):
        if not addressed_to_me(d.get("to") or ["*"], self.me):
            return None
        t = d.get("type")
        if t == "message":
            return render_message_event(self._aliased(d))
        if t == "filesystem":
            line = self._render_filesystem(d)   # keep the download/unpublish side
            if t in self.quiet:                 # effect; suppress only the notification
                return None
            return line
        return None

    def _render_filesystem(self, d):
        """Hybrid file handling: auto-download a published file small enough not
        to stall the poll loop and add its local path to the event; just announce
        larger ones for `cccp pull`. On unpublish, drop the mirror copy."""
        op, wire_path = d.get("op"), d.get("path", "")
        if op == "publish" and d.get("size", 0) <= self.autodownload_max:
            try:
                with TimeLogger(self.log, "auto_download", path=wire_path,
                                size=d.get("size", 0)):
                    local = download_to_mirror(self.client, self.prefix, self.slug,
                                               d["from"], wire_path,
                                               expect_size=d.get("size"),
                                               expect_lines=d.get("lines"))
                d = {**d, "local": str(local)}
            except (BlobError, OSError) as e:
                print(f"cccp watchtower: auto-download skipped: {e}",
                      file=sys.stderr)  # announce anyway; Claude can `cccp pull` it
                self.log.debug(
                    f"ev=auto_download_skip path={_kv(wire_path)} "
                    f"exc={type(e).__name__} msg={_kv(str(e))}")
        elif op == "unpublish":
            try:
                (mirror_dir() / self.slug / d["from"] / wire_path).unlink(
                    missing_ok=True)
            except OSError:
                pass
        return render_filesystem_event(self._aliased(d))


# ---------- subcommands ----------

# ---------- skill rendering ----------

def plugin_root():
    """The plugin install directory. This script lives at <root>/bin/cccp, so the
    root is two parents up - true both in the repo and in the installed plugin
    cache (<claude-config-dir>/plugins/cache/<mp>/<plugin>/<ver>/bin/cccp)."""
    return Path(__file__).resolve().parent.parent


def render_skill_body(template, subs):
    """Substitute the render-time @@NAME@@ tokens into a skill body template from
    `subs` (name -> value). Two tokens exist today:

        @@COMRADE_ID@@   this session's comrade id
        @@BACKEND@@      the 'CCCP Data Backend' section body (backend_status_block)

    The cell slug is deliberately NOT a token - it stays the literal placeholder
    `<slug>`, which the reader fills from its own invocation arguments. `cccp` is a
    bare command on $PATH, so the body says `cccp ...` with no path to inject.

    @@NAME@@ delimiters are used deliberately, NOT $ or {} - the skill text is full
    of shell `$vars`/`$0` and JSON `{...}` a str.format/Template pass would corrupt.
    Output is spliced verbatim by Claude Code and is NOT re-rendered, so every token
    must resolve here. Each value is substituted once and never re-scanned, so a
    value that happens to contain another token is left as-is (no recursion)."""
    for name, value in subs.items():
        template = template.replace(f"@@{name}@@", value)
    return template


# Each skill is a stack of body.template.md parts, base first, with the shared args
# outro as an implied final part (ARGS_OUTRO) - `cccp skill <name>` renders every
# part identically and joins them. The stack is written out explicitly (not derived
# from a require directive), so with a shallow family there is nothing to parse and
# nothing double-includes by accident.
SKILL_STACK = {
    "chat": ["chat"],
    "team": ["chat", "team"],
    "foreman": ["chat", "team", "foreman"],
    "foreman-with-tmux": ["chat", "team", "foreman", "foreman-with-tmux"],
}

# The trailing frame, rendered as the implied final part of every stack - NOT a
# special case; it goes through the same token substitution as the body files. The
# user's arguments are auto-appended by the harness as `ARGUMENTS: <value>` unless
# the SKILL.md references $ARGUMENTS itself - so each SKILL.md ends with a bare
# `$ARGUMENTS` and this outro is the prose that introduces it. It must be LAST.
ARGS_OUTRO = """## Your instructions

The user's invocation is on the final `User arguments:` line below:
- **If it has text** - the first token is your cell slug (use it wherever you \
see `<slug>` above); anything after it is your task or context. Get on the \
watchtower, then act on it.
- **If it is empty** - the interface does not require an argument, so no cell \
was given. Ask the user which cell to join before doing anything else."""


def _read_skill_template(part):
    """Read one skill part's body.template.md, or exit with a clear error."""
    path = plugin_root() / "skills" / part / "body.template.md"
    try:
        return path.read_text(encoding="utf-8")
    except OSError as e:
        sys.exit(f"cccp skill error: cannot read template {path}: {e}")


def compose_skill(name):
    """Return a skill's whole body: its stack of body templates plus the args outro
    as an implied final part, each rendered through the same token substitution
    (@@COMRADE_ID@@, @@BACKEND@@) and joined base-first. The backend block is
    computed once and injected as a variable, so a template places it wherever it
    reads best (chat puts it in a 'CCCP Data Backend' section)."""
    stack = SKILL_STACK.get(name)
    if stack is None:
        all_skills = sorted(set(SKILL_STACK) | set(SKILL_FNS))
        sys.exit(f"cccp skill error: unknown skill {name!r}; "
                 f"known: {', '.join(all_skills)}")
    subs = {
        "COMRADE_ID": comrade_id(),
        "BACKEND": backend_status_block(),
    }
    parts = [_read_skill_template(part) for part in stack] + [ARGS_OUTRO]
    return "\n\n".join(render_skill_body(part, subs).strip() for part in parts) + "\n"


# ---------- data setup ----------

_UUID_RE = re.compile(r'^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$', re.IGNORECASE)

_DS_DONE = """\
CCCP data collection is already set up. No action needed. \
To re-do or troubleshoot, run: \
`cccp skill data-setup --force --plugin-root='{plugin_root}' --plugin-data='{plugin_data}'`."""

_DS_START = """\
**IMPORTANT:** You MUST follow and complete this setup section before \
this skill will work. \
Do this NOW, to confirm that data collection works for the user.

The setup is to configure Claude Code's `statusLine` command to call \
`cccp-statusline`. That will make Claude session data (typically used to set a UI status line) \
available to this skill.

### 1. Invoke the `update-config` skill

This gives you the knowledge to understand and safely edit Claude Code's \
settings files.

### 2. Audit current `statusLine` state

Read all relevant settings files described by `update-config`. For each \
settings file, note any `statusLine` settings found. Understand the full \
picture of how `statusLine` is currently configured.

### 3. Decide setup action

Based on your `update-config` skill and audit results, decide the best way \
to configure Claude Code to call `cccp-statusline` as a statusLine action. \
Decide which scope is best.

Decide whether to proceed without user input (for common, simple cases) or \
to present your plan to the user and await confirmation or feedback.
- **Simple cases** — Install into user-scoped settings. Examples:
  - Zero `statusLine` configs anywhere
  - Exactly 1 `statusLine` config, user-scoped
- **Complex cases** — anything else. Present the situation and your \
recommendation to the user, then await confirmation. Examples:
  - `statusLine` appears in multiple files
  - Exactly 1 `statusLine` config but not user-scoped
  - Anything else unexpected

### 4. Configure `statusLine` to call `cccp-statusline`

Claude must have a `statusLine` command which calls this: `{plugin_bin}/cccp-statusline --plugin-data='{plugin_data}'`

Depending on whether an existing `statusLine` command exists, take one of \
these two routes:
1. **No `statusLine` command** — Use the command `{plugin_bin}/cccp-statusline --plugin-data='{plugin_data}'`, which outputs \
nothing, so Claude will correctly present no status line.
2. **Existing `statusLine` command** — Prepend `{plugin_bin}/cccp-statusline --plugin-data='{plugin_data}' --passthrough | ` \
to the existing command. `cccp-statusline` will pass stdin to stdout, so the existing command will produce the same output.

### 5. Verify setup

Verification depends on whether step 4 **edited an existing** settings \
file or **created a new** one.

**If you created a new file:** Claude Code only loads new settings files \
on session start — this session will not pick it up. Do NOT attempt the \
CLI check (it will fail). Simply tell the user: "Setup is complete. It \
will take effect in your next Claude Code session."

**If you edited an existing file:** Claude Code hot-reloads changes, so \
the statusLine should now be active. But it only runs at turn end, so \
evidence files won't exist until this turn finishes. Verify in a later \
turn:
1. Tell the user: "Setup is done — verifying in a few seconds."
2. Run `sleep 15` as a **background Bash task**. Then output NOTHING \
further and stop. This ends the current turn (triggering the statusLine).
3. The sleep completes, waking you in a fresh turn. Now run the CLI check:

```bash
cccp skill data-setup --plugin-root='{plugin_root}' --plugin-data='{plugin_data}'
```

A short confirmation means everything is working. If it still shows \
setup instructions, escalate to the user."""


class _SetupError(Exception):
    pass


def _ds_validate(plugin_data):
    data = Path(plugin_data)
    try:
        exists = data.is_dir()
    except OSError as e:
        raise _SetupError(
            f"Plugin data directory `{plugin_data}` is not accessible: {e}")
    if not exists:
        raise _SetupError(
            f"Plugin data directory `{plugin_data}` does not exist")
    try:
        f = data / ".write-test"
        f.write_text("ok")
        f.unlink()
    except OSError as e:
        raise _SetupError(
            f"Plugin data directory `{plugin_data}` is not writable: {e}")


def _ds_detect(plugin_data):
    # Harvested session telemetry lives under telemetry/claude-code/ (see
    # bin/cccp-statusline and the plugin data tree above): an auth-status.json plus one
    # <session-uuid>.json per session.
    tele = Path(plugin_data) / "telemetry" / "claude-code"
    if not (tele / "auth-status.json").exists():
        return False
    try:
        checked = 0
        for entry in os.scandir(tele):
            if entry.name.endswith(".json") and _UUID_RE.match(entry.name[:-5]):
                return True
            checked += 1
            if checked >= 3:
                break
    except OSError:
        return False
    return False


def _ds_setup(argv):
    """data-setup skill: validate, detect, emit setup body."""
    import argparse as _ap
    p = _ap.ArgumentParser(prog="cccp skill data-setup")
    p.add_argument("--plugin-root", required=True)
    p.add_argument("--plugin-data", required=True)
    p.add_argument("--force", action="store_true")
    a = p.parse_args(argv)

    plugin_bin = str(Path(__file__).resolve().parent)
    session_id = os.environ.get("CLAUDE_CODE_SESSION_ID") or "<this-session-uuid>"
    fmt = dict(plugin_root=a.plugin_root, plugin_data=a.plugin_data,
               plugin_bin=plugin_bin, session_id=session_id)
    try:
        _ds_validate(a.plugin_data)
    except _SetupError as e:
        return f"**ERROR:** {e}\n\n" + _DS_START.format(**fmt)
    if a.force or not _ds_detect(a.plugin_data):
        return _DS_START.format(**fmt)
    return _DS_DONE.format(**fmt)


SKILL_FNS = {
    "data-setup": _ds_setup,
}


def _backend_setup_guidance(backend):
    """Concise, backend-specific setup steps for the not-ready skill header."""
    if backend == "azure-blob":
        return (
            "Set it up one of two ways, then `cccp backend check azure-blob` to "
            "test it (or `cccp backend use azure-blob` to test and activate it):\n"
            "- **Use an existing hub** — `cccp config CCCP_AZURE_BLOB_ACCOUNT=<account> "
            "CCCP_AZURE_BLOB_CONTAINER=<container>`, then the token with "
            "`cccp config CCCP_AZURE_BLOB_SAS=-`, where `-` reads it from "
            "stdin so it never reaches argv. Only the user can type it: an "
            "agent's stdin is not their keyboard, so hand them that command "
            "rather than running it. `/cccp:setup` walks through it.\n"
            "- **Provision your own** — `infra/azure/apply.sh` (Terraform) stands "
            "up a hub and writes that config for you. It deploys real "
            "infrastructure and spends money: confirm with the user first.")
    if backend == "local-fs":
        # The real path, not the variable's name: the whole failure is that this
        # directory is not writable, and you cannot check a path you can't see.
        return (f"Confirm `{plugin_data_dir()}` exists and is writable, then "
                f"re-run. `$CCCP_PLUGIN_DATA` is what points cccp at it.")
    return (f"`{backend}` has no setup guidance; run `cccp config` "
            f"to inspect it.")


def backend_status_block():
    """The body of the skill's 'CCCP Data Backend' section - the @@BACKEND@@ token
    substituted by compose_skill, so the chat template places it wherever it reads
    best. Healthy: one line naming the active backend and how to list/switch (its
    presence is the 'set up correctly' signal). Not ready: the reason, concise
    backend-specific setup, and a pointer to fix it or escalate. Mirrors token-
    aware's DONE/START split. Read-only and non-mutating, and it swallows any config
    error into a helpful line so skill rendering can never fail on it."""
    try:
        cfg = resolve_config()
        backend = cfg["BACKEND"]
        ok, detail = validate_backend(cfg)   # cheap, no network
    except SystemExit as e:
        # A hard config error (an unset CCCP_PLUGIN_DATA, an unknown backend name)
        # already exits carrying the fix. Pass that text through verbatim rather
        # than flattening it to a generic line: this block is the only place the
        # reader will ever see it, since the skill body replaces the failure.
        return f"**NOT READY.** Chat will not work until this is fixed.\n\n{e}"
    except Exception:
        return ("Your CCCP config could not be resolved. Run `cccp config` "
                "to inspect it, then fix it or escalate to the user.")
    summary = BACKENDS.get(backend, {}).get("summary", "")
    # Neither line offers to list the backends: bare `cccp backend` prints only the
    # active name, and the roster lives in the setup skill, which this reader has not
    # loaded. Point at that skill instead of promising output that does not exist.
    if ok:
        return (f"Current backend: `{backend}` — {summary}. "
                f"`cccp config` shows its settings, `cccp backend use "
                f"<name>` switches; `/cccp:setup` is the skill for backend setup.")
    return (f"**NOT READY — `{backend}`: {detail}.** Chat will not work until this "
            f"is fixed.\n\n"
            f"{_backend_setup_guidance(backend)}\n\n"
            f"`cccp config` shows its settings and "
            f"`cccp backend check {backend}` re-tests it; `cccp backend use <name>` "
            f"switches. If you can't resolve it, escalate to the user and point "
            f"them at `/cccp:setup`, the skill for backend setup.")


def cmd_skill(args):
    """Render-time helper: emit a skill's fully-resolved body for its SKILL.md
    `!`cccp skill <name>`` include, which replaces the skill body wholesale.

    Template-based skills (chat, team, foreman) go through compose_skill (which
    injects @@COMRADE_ID@@ and @@BACKEND@@); callable skills (data-setup) dispatch
    directly."""
    fn = SKILL_FNS.get(args.name)
    if fn:
        sys.stdout.write(fn(args.extra) + "\n")
        return
    sys.stdout.write(compose_skill(args.name))


def read_dispatch_body(arg):
    """The message body. `-` reads stdin to EOF and sends it VERBATIM - so callers
    can heredoc or pipe any content (quotes, backticks, `$vars`, `{braces}`, a whole
    file) and never build a shell-escaped string. Nothing is stripped: what you pipe
    is exactly what lands, so line counts and trailing newlines survive intact."""
    return sys.stdin.read() if arg == "-" else arg


def cmd_dispatch(args):
    """Append a message to my gazette - the whole of sending, in v2."""
    cfg = resolve_config()
    client = make_backend(cfg)
    slug = slugify(args.cell)
    me = comrade_id()
    log = setup_logging(cfg, slug, me, sys.argv)
    client.log = log
    with subcommand_footer(log):
        # A missing body is legal ONLY as a deadline-only call - the flag is what
        # licenses it. A plain forgotten body still errors, exactly as before.
        if args.body is None and args.deadline is None:
            sys.exit("error: body is required (or pass --deadline to set or clear "
                     "a deadline without sending anything)")
        if args.standing and args.deadline is None:
            sys.exit("error: --standing requires --deadline")
        if args.standing and args.deadline == "none":
            sys.exit("error: --standing cannot be combined with --deadline none "
                     "(`--deadline none` is how you stop a standing deadline)")
        limit = None
        if args.deadline is not None:
            # A deadline on a broadcast is ambiguous - "everyone replies" or
            # "someone replies"? - and per-comrade timers stay unambiguous without
            # it, so require the caller to say who they are waiting on.
            if not args.to or "*" in args.to:
                sys.exit("error: --deadline requires an explicit --to")
            if args.deadline != "none":
                limit = args.deadline
                if parse_duration(limit) is None:
                    sys.exit(f"error: --deadline {args.deadline!r} is not a duration "
                             f"(e.g. 180s, 10m, 3h30m) or 'none'")
        # Resolve any alias in --to back to a raw comrade id (the wire only ever
        # carries ids). Aliases and ids are distinguishable, so this is a no-op
        # for id/`*` recipients and errors on an unknown alias.
        to = args.to if args.to else ["*"]
        if any(not is_comrade_id(t) and t != "*" for t in to):
            amap = load_aliases(slug, me)
            resolved = []
            for t in to:
                cid, err = resolve_recipient(amap, t)
                if err:
                    sys.exit(f"error: {err} - known aliases: "
                             f"{', '.join(sorted(amap.values())) or '(none)'}")
                resolved.append(cid)
            to = resolved
        sent = None
        if args.body is not None:
            body = read_dispatch_body(args.body)
            d = {
                "type": "message",
                "ts": now_iso(),
                "from": me,
                "to": to,
                "body": body,
            }
            sent = d["ts"]
            with TimeLogger(log, "dispatch_append", body_chars=len(body),
                            to_count=len(args.to) if args.to else 0):
                append_dispatch(client, cfg["PREFIX"], slug, me, d)

        # Deadlines are local watchtower state - nothing about them goes on the
        # wire. One record per recipient, so multiple --to fan out to independent
        # timers. Armed after the send, so the clock starts when the message
        # actually went out.
        if args.deadline is not None:
            # `ts` is the MESSAGE's ts, not the arm time - which makes it a real
            # handle: `cccp read <slug> --from <me> --ts <ts>` returns the very
            # message we are awaiting a reply to, for us after a compaction or for
            # the comrade we are chasing. Exact-match on a stored string, so clock
            # skew across the cell is irrelevant. It doubles as the timer's anchor,
            # so the clock starts when the message went out rather than after the
            # append (a network round-trip on azure-blob).
            #
            # Omitted entirely when there is no message: a bodyless arm may relate
            # to something said turns ago, or to nothing at all, and cccp cannot
            # know which. Absent beats pointing at nothing - and its absence tells
            # the reader there is no specific message to re-read.
            rec = {"ev": "deadline", "to": None, "limit": limit}
            if sent:
                rec["ts"] = sent
            if args.standing:
                rec["standing"] = True
            with TimeLogger(log, "deadline_send", to_count=len(to),
                            limit=limit or "none", standing=bool(args.standing)):
                r = inbox_send(slug, me, [{**rec, "to": t} for t in to])
            if r.returncode == 1:
                # Timers are watchtower-owned, and a fresh watchtower resets
                # its inbox - so an arm with no live watchtower is not
                # deferred, it is DISCARDED. Fail loudly (#13) instead of the
                # silent futility an operator only discovers from an alert
                # that never fires.
                sys.exit(f"error: no live watchtower for cell {slug!r} to own "
                         f"this deadline - the record was discarded"
                         + ("; the message itself was sent" if sent else "")
                         + ". Arm a watchtower, then re-run.")
            if r.returncode > 1:
                sys.exit(f"pkill failed: "
                         f"{r.stderr.decode().strip() or r.returncode}")
            if limit:
                print(f"deadline {limit} armed for {', '.join(to)}")
            else:
                print(f"deadline cleared for {', '.join(to)}")


def cmd_watchtower(args):
    """Run the long-lived live-event stream for a cell (under the Monitor tool)."""
    # Tag the ps-visible argv with this session's comrade id by re-exec'ing
    # once with `-- <id>` appended, so an ad-hoc `ps aux | grep 'cccp
    # watchtower'` tells apart many watchtowers - the id is session-suffixed,
    # so even siblings on the same cell and host are distinguishable. A re-exec
    # rather than argv memory tricks: fully portable, and exec keeps pid/ppid/
    # environ, so Monitor parenting, the ppid watchdog, and the wake pkill
    # match (a space still follows the slug) are all unaffected. comrade_id()
    # is pure and local, so the tag is identical to the `me` computed below.
    # The tag is always the trailing `("--", id)` pair; main() strips it before
    # argparse (argparse's own `--` handling leaks through subparsers), and its
    # presence is the already-re-exec'd marker that stops a loop.
    if sys.argv[-2:-1] != ["--"]:
        os.execv(sys.executable,
                 [sys.executable, sys.argv[0], *sys.argv[1:], "--", comrade_id()])
    cfg = resolve_config()
    client = make_backend(cfg)
    slug = slugify(args.cell)
    me = comrade_id()
    log = setup_logging(cfg, slug, me, sys.argv)
    client.log = log
    # No subcommand_footer here - the Watchtower emits its own ev=watchtower_stop
    # with a reason, which is the richer lifecycle record for a long-lived
    # process.
    Watchtower(client, cfg["PREFIX"], slug, me, args.idle * 60, log=log,
               quiet=args.quiet, trigger=args.alias_trigger,
               autodownload_max=cfg["AUTODOWNLOAD_MAX"]).run()


def cmd_wake(args):
    """SIGUSR1 any local watchtower for this cell -- reset to fast-poll mode and
    poll immediately. Use when you know an event is waiting and don't want to
    wait out the current idle gap.

    Sibling-session caveat: this pkill-USR1s every watchtower whose cmdline
    matches wake_pattern(slug), and sibling Claude sessions on the same
    host+user watching the same cell all match. All such siblings will be
    woken. The collateral cost is trivial - the spurious sibling spends a few
    extra seconds in fast-poll before its ladder reasserts - so this is the
    documented, accepted side-effect. Surgical per-session signalling is now
    possible (pid_path carries each watchtower's pid, keyed by comrade) but
    not worth the divergence while the broadcast stays this cheap.
    """
    slug = slugify(args.cell)
    # Use the bare user@host for the log path - the exact session-suffixed id
    # doesn't matter here (wake is host-local and signals every sibling anyway),
    # and each sibling watchtower logs at its own suffixed path independently.
    cfg = resolve_config()
    me = base_comrade_id()
    log = setup_logging(cfg, slug, me, sys.argv)
    with subcommand_footer(log):
        r = wake_watchtowers(slug)
        log.debug(f"ev=wake_sent slug={_kv(slug)} pkill_rc={r.returncode}")
        if r.returncode == 0:
            print(f"woke watchtower(s) for cell {slug!r}")
        elif r.returncode == 1:
            sys.exit(f"no local watchtower found for cell {slug!r}")
        else:
            sys.exit(f"pkill failed: {r.stderr.decode().strip() or r.returncode}")


def cmd_stop(args):
    """Ask my own watchtower(s) for this cell to exit, via the inbox.

    Kill-free termination (#16): the inbox is keyed (cell, comrade), so this can
    only ever stop THIS comrade's watchtowers - never a peer's - with no pgrep
    and no signals. Works regardless of parentage, so it also cleanly retires a
    detached instance that the ppid watchdog cannot reach. The record is drained
    within ms when a watchtower is alive (inbox_send wakes it); a leftover
    record is truncated unread by the next watchtower's inbox reset, so a stale
    stop can never kill a future one."""
    slug = slugify(args.cell)
    me = comrade_id()
    cfg = resolve_config()
    log = setup_logging(cfg, slug, me, sys.argv)
    with subcommand_footer(log):
        r = inbox_send(slug, me, [{"ev": "shutdown", "ts": now_iso()}])
        log.debug(f"ev=stop_sent slug={_kv(slug)} pkill_rc={r.returncode}")
        if r.returncode == 0:
            print(f"stop requested; my watchtower for cell {slug!r} exits on "
                  f"its next inbox drain (woken now)")
        elif r.returncode == 1:
            sys.exit(f"no local watchtower found for cell {slug!r} - nothing "
                     f"to stop (request discarded by the next one's inbox reset)")
        else:
            sys.exit(f"pkill failed: {r.stderr.decode().strip() or r.returncode}")


def cmd_status(args):
    """Report my watchtower's state for a cell: alive (verified against the
    process table via the argv ownership tag), stopped-with-reason, or
    died-hard (stale pid record). Exit 0 only when alive."""
    slug = slugify(args.cell)
    me = comrade_id()
    cfg = resolve_config()
    log = setup_logging(cfg, slug, me, sys.argv)
    with subcommand_footer(log):
        state, detail = watchtower_status(slug, me)
        log.debug(f"ev=status state={state}")
        print(detail)
        if state != "alive":
            sys.exit(1)


def cmd_read(args):
    """Print cell message history - the on-demand history tool. Filter by sender
    (--from), recipient (--to), and select with --ts or --last."""
    cfg = resolve_config()
    slug = slugify(args.cell)
    # Read-only, so the log path uses the bare user@host - it avoids requiring a
    # session id (this can run outside Claude) and the exact id is immaterial here.
    log = setup_logging(cfg, slug, base_comrade_id(), sys.argv)
    client = make_backend(cfg, log=log)
    prefix = cfg["PREFIX"]

    with subcommand_footer(log):
        senders = [args.from_] if args.from_ else cell_roster(client, prefix, slug)
        msgs = []
        for sender in senders:
            st, body = client.get(gazette_path(prefix, slug, sender))
            if st != 200:
                continue
            for line in body.splitlines():
                try:
                    d = json.loads(line)
                except ValueError:
                    print(f"cccp: warning: skipping unparseable gazette line "
                          f"from {sender}", file=sys.stderr)
                    continue
                if d.get("type") == "message":
                    msgs.append(d)

        if args.to:
            msgs = [m for m in msgs if addressed_to_me(m.get("to") or ["*"], args.to)]
        msgs.sort(key=lambda m: m.get("ts", ""))

        if args.ts:
            m = next((m for m in msgs if m.get("ts") == args.ts), None)
            if not m:
                sys.exit(f"error: no message with ts={args.ts!r}")
            out = message_read_output(m, full=args.full)
            sys.stdout.write(out if out.endswith("\n") else out + "\n")
            return

        if args.last is not None:
            if args.last < 1:
                sys.exit("error: --last must be >= 1")
            msgs = msgs[-args.last:]

        if not msgs:
            print("(no messages)")
            return
        for m in msgs:
            print(f"from={m.get('from')} to={render_to(m.get('to', ['*']))} ts={m.get('ts')}")
            print(m.get("body", ""))
            print()


def cmd_rm(args):
    """Delete a cell and all its blobs. Destructive and user-directed: prints a
    summary first, and only deletes when --yes is given."""
    cfg = resolve_config()
    slug = slugify(args.cell)
    log = setup_logging(cfg, slug, base_comrade_id(), sys.argv)
    client = make_backend(cfg, log=log)
    with subcommand_footer(log):
        head = cell_head(cfg["PREFIX"], slug)
        blobs = list(client.list(head))
        if not blobs:
            print(f"cell {slug!r} is empty or does not exist - nothing to delete")
            return
        comrades = cell_roster(client, cfg["PREFIX"], slug)
        print(f"cell {slug!r}: {len(blobs)} blobs across {len(comrades)} comrades "
              f"({', '.join(comrades)})")
        if not args.yes:
            print("dry run - pass --yes to actually delete")
            return
        for name in blobs:
            st = client.delete(name)
            print(f"deleted {name} -> {st}")
        print(f"cell {slug!r} removed")


def cmd_publish(args):
    """Upload a file as a block blob under my files/ area and announce it in my
    gazette. Single-PUT only - files over PUBLISH_MAX need ad-hoc staging."""
    cfg = resolve_config()
    client = make_backend(cfg)
    slug = slugify(args.cell)
    me = comrade_id()
    log = setup_logging(cfg, slug, me, sys.argv)
    client.log = log
    with subcommand_footer(log):
        src = Path(os.path.abspath(os.path.expanduser(args.path)))
        if not src.is_file():
            sys.exit(f"error: not a regular file: {src}")
        size = src.stat().st_size
        if size > PUBLISH_MAX:
            sys.exit(
                f"error: {src} is {size} bytes, over the {PUBLISH_MAX}-byte single-PUT "
                f"limit. cccp publish does one urllib PUT - it does not stage block "
                f"lists. To publish a file this large, either:\n"
                f"  1. ask the user to install azcopy (pip/brew) and upload with it, or\n"
                f"  2. write an ad-hoc Put Block + Put Block List uploader, reading this "
                f"script ({__file__}) as a reference for the SAS/REST setup.")

        rel = str(src).lstrip("/")
        data = src.read_bytes()
        blob = published_blob(cfg["PREFIX"], slug, me, f"files/{rel}")
        with TimeLogger(log, "publish_upload", path=rel, size=size):
            st = client.put_block(blob, data)
        if st != 201:
            raise BlobError(st, b"publish upload failed")
        # Read the size back from the store (#7): a 201 whose blob is absent or
        # truncated must fail the publish, not surface as a peer's failed pull.
        st, got = client.stat(blob)
        if st != 200 or got != size:
            raise BlobError(st, f"publish read-back failed: store has "
                                f"{got if got is not None else 'no blob'}, "
                                f"uploaded {size} bytes; the publish was "
                                f"NOT delivered".encode())

        d = {"type": "filesystem", "op": "publish", "ts": now_iso(), "from": me,
             "to": args.to if args.to else ["*"], "path": f"files/{rel}", "size": size}
        if src.suffix.lower() in TEXT_EXTENSIONS:
            d["lines"] = data.count(b"\n")
        with TimeLogger(log, "publish_announce", path=rel):
            append_dispatch(client, cfg["PREFIX"], slug, me, d)
        print(f"published {rel} ({size} bytes)")


def cmd_unpublish(args):
    """Delete a previously-published file blob and announce the withdrawal.
    Uses the same path that was given to publish."""
    cfg = resolve_config()
    client = make_backend(cfg)
    slug = slugify(args.cell)
    me = comrade_id()
    log = setup_logging(cfg, slug, me, sys.argv)
    client.log = log
    with subcommand_footer(log):
        src = Path(os.path.abspath(os.path.expanduser(args.path)))
        rel = str(src).lstrip("/")
        client.delete(published_blob(cfg["PREFIX"], slug, me, f"files/{rel}"))  # 404 ok
        d = {"type": "filesystem", "op": "unpublish", "ts": now_iso(), "from": me,
             "to": args.to if args.to else ["*"], "path": f"files/{rel}"}
        append_dispatch(client, cfg["PREFIX"], slug, me, d)
        print(f"unpublished {rel}")


def cmd_pull(args):
    """Download published files matching the given path expressions into the
    local mirror. Synchronous; on success it is silent and exits 0, so Claude
    can chain it: `cccp pull <cell> <paths> && <follow-up>`."""
    cfg = resolve_config()
    slug = slugify(args.cell)
    # A fetch, not a participation event; the log path uses the bare user@host
    # (no session id required, exact id immaterial).
    log = setup_logging(cfg, slug, base_comrade_id(), sys.argv)
    client = make_backend(cfg, log=log)
    prefix = cfg["PREFIX"]

    with subcommand_footer(log):
        # Catalogue currently-published files across all gazettes; a later unpublish
        # cancels an earlier publish of the same (sender, path). The value is the
        # publish dispatch, kept so its claimed size / line count can be verified.
        catalogue = {}  # (sender, wire_path) -> publish dispatch dict
        for sender in cell_roster(client, prefix, slug):
            st, body = client.get(gazette_path(prefix, slug, sender))
            if st != 200:
                continue
            for line in body.splitlines():
                try:
                    d = json.loads(line)
                except ValueError:
                    print(f"cccp: warning: skipping unparseable gazette line "
                          f"from {sender}", file=sys.stderr)
                    continue
                if d.get("type") != "filesystem":
                    continue
                key = (sender, d.get("path", ""))
                if d.get("op") == "publish":
                    catalogue[key] = d
                elif d.get("op") == "unpublish":
                    catalogue.pop(key, None)

        # Match each published file's original path against the expressions: an exact
        # match, or the expression is a directory prefix of it.
        exprs = [os.path.abspath(os.path.expanduser(e)) for e in args.expr]
        wanted = [(sender, wp) for (sender, wp) in catalogue
                  if any(display_path(wp) == e
                         or display_path(wp).startswith(e.rstrip("/") + "/")
                         for e in exprs)]
        if not wanted:
            sys.exit(f"error: no publish announcement matches {args.expr} - "
                     f"either it was never published, or the announce never "
                     f"reached the store (pull only sees announcements, not "
                     f"the files/ blobs themselves)")
        for sender, wire_path in wanted:
            meta = catalogue[(sender, wire_path)]
            try:
                with TimeLogger(log, "pull_download", path=wire_path,
                                size=meta.get("size", 0)):
                    download_to_mirror(client, prefix, slug, sender, wire_path,
                                       expect_size=meta.get("size"),
                                       expect_lines=meta.get("lines"))
            except BlobError as e:
                sys.exit(f"error: {e}")
        # success: silent, exit 0


# ---------- argparse ----------

def cmd_aliases(args):
    """List this cell's local alias map (name = id), one per line. Purely local -
    no config, no network."""
    amap = load_aliases(slugify(args.cell), comrade_id())
    if not amap:
        print("(no aliases)")
        return
    for cid, name in sorted(amap.items(), key=lambda kv: kv[1]):
        print(f"{name} = {cid}")


def cmd_alias(args):
    """Show or set an alias in the local map. One arg shows (by name or id); two
    args set/correct - order-free, since an id (has @:) and an alias never look
    alike. Local only."""
    slug, me = slugify(args.cell), comrade_id()
    amap = load_aliases(slug, me)
    parts = args.args
    if len(parts) == 1:
        q = parts[0]
        if is_comrade_id(q):
            print(f"{q} = {amap[q]}" if q in amap else f"{q}: no alias")
        else:
            cid = next((i for i, a in amap.items() if a == q), None)
            print(f"{q} = {cid}" if cid else f"{q}: no such alias")
    elif len(parts) == 2:
        ids = [p for p in parts if is_comrade_id(p)]
        names = [p for p in parts if not is_comrade_id(p)]
        if len(ids) != 1 or len(names) != 1:
            sys.exit("error: set needs exactly one comrade id and one alias")
        learn_alias(amap, ids[0], names[0])   # reassign semantics; discard event
        save_aliases(slug, me, amap)
        print(f"{names[0]} = {ids[0]}")
    else:
        sys.exit("error: alias takes <name-or-id> (show) or <name> <id> (set)")


def cmd_unalias(args):
    """Remove an alias from the local map, by name. Local only."""
    slug, me = slugify(args.cell), comrade_id()
    amap = load_aliases(slug, me)
    cid = next((i for i, a in amap.items() if a == args.name), None)
    if cid is None:
        sys.exit(f"error: no such alias {args.name!r}")
    del amap[cid]
    save_aliases(slug, me, amap)
    print(f"cleared {args.name}")


# ---------- backend selection ----------

def validate_backend(cfg, network=False):
    """Read-only health check of the resolved backend. Returns (ok, detail) and
    never mutates anything. local-fs checks its data dir is writable; azure-blob
    checks the required params are present, and with network=True also does one
    cheap container LIST to confirm the SAS actually reaches the hub."""
    backend = cfg["BACKEND"]
    if backend == "local-fs":
        root = Path(cfg["PARAMS"].get("root")
                    or backend_dir("local-fs")).expanduser()
        probe = root
        while not probe.exists() and probe != probe.parent:
            probe = probe.parent
        if os.access(probe, os.W_OK):
            return True, "ready"
        return False, f"store root not writable: {root}"
    if backend == "azure-blob":
        params = cfg["PARAMS"]
        missing = [k.upper() for k in ("account", "container", "sas")
                   if not params.get(k)]
        if missing:
            return False, "missing " + ", ".join(missing)
        if not network:
            return True, "configured"
        try:
            AzureBlobBackend(params["account"], params["container"], params["sas"]) \
                .list(cell_head(cfg["PREFIX"], "__cccp_healthcheck__"))
            return True, "ready"
        except Exception as e:
            return False, f"cannot reach container ({type(e).__name__})"
    return False, f"unknown backend {backend!r}"


def _write_kv(path, key, value):
    """Set KEY=value in a flat KEY=value config file, preserving every other line
    and comment; `value=None` removes the key instead. Creates the file and its
    parents if absent, and keeps it owner-only - a secrets file holds a SAS.

    Shared by every config and secrets file, global and per-backend, so all of
    them keep identical dotenv semantics and none grows a writer of its own."""
    path.parent.mkdir(parents=True, exist_ok=True)
    out, replaced = [], False
    if path.exists():
        for line in path.read_text().splitlines():
            s = line.strip()
            if s and not s.startswith("#") and s.split("=", 1)[0].strip() == key:
                if value is not None:
                    out.append(f"{key}={value}")
                replaced = True
            else:
                out.append(line)
    if not replaced and value is not None:
        out.append(f"{key}={value}")
    path.write_text("\n".join(out) + "\n" if out else "")
    path.chmod(0o600)


def _write_setting(key, value):
    """Set KEY=value in the global config file - cccp's global state."""
    _write_kv(global_config_path(), key, value)


@contextlib.contextmanager
def _as_active(name):
    """Resolve config as if `name` were the active backend, without persisting that
    choice - what `use` and `check` both need to validate a backend before (or
    without) switching to it. Process env is the highest-precedence layer, so
    overriding the selector there is exactly how a caller would have selected it.
    The previous value is restored on exit, so one check can never leak into the
    next resolution in the same process."""
    prev = os.environ.get("CCCP_ACTIVE_BACKEND")
    os.environ["CCCP_ACTIVE_BACKEND"] = name
    try:
        yield resolve_config()
    finally:
        if prev is None:
            os.environ.pop("CCCP_ACTIVE_BACKEND", None)
        else:
            os.environ["CCCP_ACTIVE_BACKEND"] = prev


def _require_backend(name):
    """Exit unless `name` is a known backend."""
    if name not in BACKENDS:
        sys.exit(f"error: unknown backend {name!r}; known: "
                 f"{', '.join(sorted(BACKENDS))}")


def _backend_use(name):
    """Validate `name` as the active backend, then persist it to settings. Refuses
    to switch to a backend that isn't ready - it never leaves the user pointed at a
    broken store, and never silently downgrades."""
    _require_backend(name)
    current = resolve_config()["BACKEND"]
    with _as_active(name) as cfg:
        ok, detail = validate_backend(cfg, network=True)
    if not ok:
        sys.exit(f"error: {name!r} is not ready: {detail}. Active backend "
                 f"unchanged ({current}).\n\n{_backend_setup_guidance(name)}")
    _write_setting("CCCP_ACTIVE_BACKEND", name)
    print(f"Active backend set to {name} ({detail}).")


def _backend_check(name):
    """Validate any backend, active or not, without switching to it - the 'test it
    before I commit to it' verb. Exits non-zero when it is not ready, so a caller
    can branch on it."""
    _require_backend(name)
    with _as_active(name) as cfg:
        ok, detail = validate_backend(cfg, network=True)
    if ok:
        print(f"{name}: OK ({detail}).")
        return
    sys.exit(f"{name}: NOT READY - {detail}.\n\n{_backend_setup_guidance(name)}")


def _config_keys(backend):
    """The keys `cccp config` will write for a backend: its params (secrets
    included - see _backend_params), plus PREFIX where the backend uses one.
    local-fs is isolated by its own root dir and so exposes no prefix key (see
    DEFAULT_PREFIX); its one param, ROOT, is optional with a lazy default, so
    it remains the zero-setup backend."""
    spec = BACKENDS[backend]
    return _backend_params(spec) + (("PREFIX",) if spec["prefix_default"] else ())


def _fmt_param(backend, key, value):
    """One param's display value. A secret is never printed - only whether it is set,
    and how long - so `cccp config` output stays safe to paste into an issue or
    leave sitting in a transcript. The value is on disk if you truly need it."""
    if not value:
        return "<missing>"
    if key in BACKENDS[backend].get("secrets", ()):
        return f"<set, {len(value)} chars>"
    return value


def _config_destinations():
    """Every settable key -> the data-dir-relative file it lives in. Built from
    the BACKENDS registry, so adding a backend auto-claims its key namespace
    with nothing extra to register. Exact-match only: prefix routing would
    happily write a typo'd key and leave a <missing> to debug later."""
    dest = {"CCCP_DEBUG": "config", "CCCP_AUTODOWNLOAD_MAX": "config"}
    for name, spec in BACKENDS.items():
        for key in _config_keys(name):
            file = "secrets" if key in spec["secrets"] else "config"
            dest[_backend_key(name, key)] = f"backend/{name}/{file}"
    return dest


def _global_rows(cfg):
    """The global section's (key, shown, layers, raw) rows: the tree root, the
    debug switch (rendered as its effective boolean - unset is its normal state,
    not a configuration gap), and the backend selection that the sections below
    hang off."""
    root = str(plugin_data_dir())
    src = cfg["SOURCES"]
    return [
        ("CCCP_PLUGIN_DATA", root, ["env"], root),
        ("CCCP_DEBUG", "on" if _truthy(cfg["DEBUG"]) else "off",
         src.get("CCCP_DEBUG", []), cfg["DEBUG"]),
        ("CCCP_AUTODOWNLOAD_MAX", cfg["AUTODOWNLOAD_MAX_RAW"],
         src.get("CCCP_AUTODOWNLOAD_MAX", []), cfg["AUTODOWNLOAD_MAX_RAW"]),
        ("CCCP_ACTIVE_BACKEND", cfg["BACKEND"],
         src.get("CCCP_ACTIVE_BACKEND", []), cfg["BACKEND"]),
    ]


def _backend_rows(name, cfg):
    """One backend's (key, shown, layers, raw) rows, resolved as if active."""
    rows = []
    for key in _config_keys(name):
        qualified = _backend_key(name, key)
        raw = cfg["PREFIX"] if key == "PREFIX" else cfg["PARAMS"].get(key.lower())
        rows.append((qualified, _fmt_param(name, key, raw),
                     cfg["SOURCES"].get(qualified, []), raw))
    return rows


def _print_config_dump():
    """The read half of `cccp config`: the full resolved picture - globals, then
    every backend, the active one first, each introduced by an
    'Active backend:' / 'Inactive backend:' line.

    It resolves rather than dumping files, because a file is one layer of three
    and the environment outranks it - printing a file alone would show values
    cccp is not using. `Set by` names the layer that won each key BY ITS
    data-dir-relative file path (or env/default/unset), so a reader can combine
    it with CCCP_PLUGIN_DATA and go straight to the file; a key set in more
    than one layer shows every layer it shadows.

    One width calculation spans all sections, so the dump reads as a single
    table. Value goes LAST because it is the one unbounded column - a data-dir
    path can run 90 characters and would otherwise shove `Set by` off the right
    edge. It also reads as a sentence: <key>, set by <layer>, is <value>."""
    cfg = resolve_config()
    active = cfg["BACKEND"]
    sections = [(None, None, _global_rows(cfg))]
    for name in [active] + sorted(b for b in BACKENDS if b != active):
        title = (f"{'Active' if name == active else 'Inactive'} "
                 f"backend: {name}")
        if not _config_keys(name):
            sections.append((title, name, []))
            continue
        with _as_active(name) as bcfg:
            sections.append((title, name, _backend_rows(name, bcfg)))
    deco = []
    for title, name, rows in sections:
        drows = []
        for key, shown, layers, raw in rows:
            # No layer set it: either a default filled it in (PREFIX) or nothing
            # did. Saying "default" for a missing required param would imply a
            # default exists to fall back on, and none does.
            origin = layers[-1] if layers else ("default" if raw else "unset")
            note = (f"   <- shadows {', '.join(reversed(layers[:-1]))}"
                    if len(layers) > 1 else "")
            drows.append((key, origin, shown + note))
        deco.append((title, name, drows))
    all_rows = [r for _, _, rows in deco for r in rows]
    kw = max(len(r[0]) for r in all_rows)
    sw = max([len(o) for _, o, _ in all_rows] + [len("Set by")])
    print(f"  {'Config key':<{kw}}  {'Set by':<{sw}}  Value")
    for title, name, drows in deco:
        if title:
            print(f"\n  {title}")
            if not drows:
                print(f"  ({name} has no parameters of its own)")
        for key, origin, shown in drows:
            print(f"  {key:<{kw}}  {origin:<{sw}}  {shown}".rstrip())


def _config_set(assignments):
    """The write half of `cccp config`: KEY=VALUE pairs, each auto-routed to its
    proper file by the registry map (_config_destinations). Keys are canonical
    CCCP_* names exactly as the dump prints them - no short forms, because the
    flat command has no backend context to resolve them against, and one
    copy-paste from the dump beats a resolution algorithm.

    A VALUE of `-` reads the value from stdin (the `cccp dispatch` idiom - it
    keeps a SAS out of shell history and out of the transcript); an empty VALUE
    removes the key. The confirmation names the destination file in the dump's
    Set-by vocabulary, so which file was touched is never a mystery - and a
    write the environment is currently shadowing says so on the spot, instead
    of succeeding and being silently ignored."""
    dest = _config_destinations()
    env = _env_layer()
    touched = set()
    for item in assignments:
        if "=" not in item:
            sys.exit(f"error: expected KEY=VALUE, got {item!r}.")
        key, value = item.split("=", 1)
        key = key.strip()
        if key == "CCCP_ACTIVE_BACKEND":
            sys.exit("error: CCCP_ACTIVE_BACKEND is not set here - run "
                     "`cccp backend use <name>`, which validates the backend "
                     "before switching and never leaves you on a broken store.")
        if key == "CCCP_PLUGIN_DATA":
            sys.exit("error: CCCP_PLUGIN_DATA is environment-only - it locates "
                     "the config tree, so it cannot live inside it (the "
                     "plugin's SessionStart hook exports it).")
        rel = dest.get(key)
        if rel is None:
            sys.exit(f"error: unknown key {key!r} - known keys:\n  "
                     + "\n  ".join(sorted(dest)))
        if value == "-":
            value = sys.stdin.read().strip()
            if not value:
                # Not a terminal means nobody could have typed anything: the
                # caller is a script or an agent, and an agent's stdin is not
                # the user's keyboard. That is the whole reason this path
                # exists, so say so here rather than let it read as a
                # mysterious empty pipe.
                hint = "" if sys.stdin.isatty() else (
                    " stdin is not a terminal, so nothing could be typed into "
                    "it. An agent cannot read the user's keyboard: have the "
                    "user run this command themselves, in their own terminal, "
                    "with CCCP_PLUGIN_DATA set and cccp's full path.")
                sys.exit(f"error: no value for {key} on stdin.{hint}")
        # Typed keys are vetted at write time too, so a bad value dies here
        # with context instead of at the next resolve_config in some other
        # command. (Read-side validation still stands: env bypasses this.)
        if key == "CCCP_AUTODOWNLOAD_MAX" and value \
                and parse_size(value) is None:
            sys.exit(f"error: {key} {value!r} is not a size "
                     f"('4096', '512k', '10m', '1g')")
        _write_kv(plugin_data_dir() / rel, key, value or None)
        print(f"{'Set' if value else 'Removed'} {key} ({rel})")
        if key in env:
            print(f"warning: {key} is set in your environment, which shadows "
                  f"this write")
        if rel.startswith("backend/"):
            touched.add(rel.split("/")[1])
    for name in sorted(touched):
        print(f"\nValidate it with: cccp backend check {name}")


def cmd_config(args):
    """`cccp config` is about understanding and managing cccp's local config
    files: bare, the full resolved dump with provenance; with KEY=VALUE
    assignments, writes auto-routed to the proper file. Operations on the
    backend itself (validation, switching) live under `cccp backend`."""
    if args.assignments:
        _config_set(args.assignments)
    else:
        _print_config_dump()


def cmd_backend(args):
    """`cccp backend` names the active backend, and nothing else. Its subcommands
    are the backend OPERATIONS: `check` reports health, `use` switches. Reading
    and writing config - local text files - is `cccp config`'s job.

    Bare, it is plumbing: one token on stdout, no network, so `$(cccp backend)` is a
    value a script can branch on. Everything it used to print had a better owner -
    config belongs to `cccp config`, health to `check` (the verb that should pay for
    a network probe rather than making `which backend am I on` wait on a container
    LIST), and the roster of backends to skills/setup/SKILL.md."""
    action = getattr(args, "action", None)
    if action == "use":
        _backend_use(args.name)
        return
    if action == "check":
        _backend_check(args.name or resolve_config()["BACKEND"])
        return
    print(resolve_config()["BACKEND"])


def build_parser():
    p = argparse.ArgumentParser(
        prog="cccp",
        description="Claude-to-Claude Communication Program (pluggable backends).",
    )
    # Explicit metavar lists only the operator-facing subcommands. `skill` is a
    # render-time internal (the SKILL.md `!`cccp skill ...`` include calls it, not
    # a human) - it stays a valid choice, so `cccp skill` and `cccp skill --help`
    # both work, but it is omitted here (and given no help= below) so it never
    # shows in top-level `cccp --help`.
    sub = p.add_subparsers(
        dest="cmd", required=True,
        metavar="{config,backend,dispatch,watchtower,wake,stop,status,read,rm,"
                "publish,unpublish,pull,aliases,alias,unalias}")

    # No `help=` kwarg: argparse only emits a subcommand's detail line when a
    # truthy help is passed, so omitting it (NOT help=SUPPRESS, which is itself a
    # truthy string and prints literally as "==SUPPRESS==") keeps `skill` out of
    # the detail list. Combined with the metavar above, it's fully hidden from
    # top-level help while `cccp skill` / `cccp skill --help` still work. It takes
    # no arguments - its output is fully determined by the comrade id.
    sk = sub.add_parser(
        "skill",
        description="Emit a skill's fully-resolved body text (render-time helper; "
                    "replaces the SKILL.md body via `!`cccp skill <name>``).")
    sk.add_argument("name", nargs="?", default="chat",
                    help="Skill to render (default chat). Its stack of "
                         "skills/<part>/body.template.md is concatenated base-first.")
    sk.add_argument("extra", nargs=argparse.REMAINDER, help=argparse.SUPPRESS)
    sk.set_defaults(func=cmd_skill)

    bk = sub.add_parser(
        "backend",
        help="Print the active data backend; subcommands validate and switch it.",
        description="Print the active backend's name and nothing else - no network, "
                    "so it is usable as a script value. Its subcommands do the work.")
    bk_sub = bk.add_subparsers(dest="action", metavar="{check,use}")

    bk_check = bk_sub.add_parser(
        "check", help="Validate a backend's health without switching to it.")
    bk_check.add_argument("name", nargs="?", default=None,
                          help="Backend to test; omit for the active one.")

    bk_use = bk_sub.add_parser("use", help="Switch the active backend and persist it.")
    bk_use.add_argument("name", help="Backend to activate; an unknown name "
                                     "lists the valid ones.")

    bk.set_defaults(func=cmd_backend, action=None, name=None)
    bk_use.set_defaults(func=cmd_backend, action="use")
    bk_check.set_defaults(func=cmd_backend, action="check")

    cf = sub.add_parser(
        "config",
        help="Show the full resolved config, or set CCCP_* keys "
             "(auto-routed to the proper file).",
        description="Bare: the full resolved config - globals, then every "
                    "backend, active first - with a Set-by column naming "
                    "the winning layer by its data-dir-relative file path. With "
                    "KEY=VALUE assignments: write keys, auto-routed to the "
                    "proper file. Backend operations (validate, switch) live "
                    "under `cccp backend`.")
    cf.add_argument("assignments", nargs="*", metavar="KEY=VALUE",
                    help="Canonical CCCP_* keys exactly as the dump prints them. "
                         "A VALUE of `-` reads the value from stdin (keeping a "
                         "secret out of shell history); an empty VALUE removes "
                         "the key. Omit every assignment to show the config.")
    cf.set_defaults(func=cmd_config)

    disp = sub.add_parser("dispatch", help="Send a message to a cell.")
    disp.add_argument("cell", help="Cell slug.")
    disp.add_argument("--to", action="append", default=[], metavar="COMRADE",
                      help="Repeatable. Comrade id or alias; omit for broadcast.")
    disp.add_argument("--deadline", metavar="DURATION",
                      help="Expect a reply from each --to within DURATION "
                           "(180s, 10m, 3h30m); `none` clears. Local to this "
                           "session's watchtower - nothing goes on the wire. "
                           "May be used with no message body, to set or clear a "
                           "deadline without sending anything.")
    disp.add_argument("--standing", action="store_true",
                      help="Make --deadline recurring: it re-arms on every reply "
                           "and after every miss, so a comrade expected to report "
                           "on a cadence always has a live timer. On-time replies "
                           "re-arm it quietly; silence alerts every DURATION until "
                           "they report or you pass --deadline none.")
    disp.add_argument("body", nargs="?", help="Message text, or `-` to read the body from "
                                   "stdin verbatim (heredoc-friendly).")
    disp.set_defaults(func=cmd_dispatch)

    wt = sub.add_parser("watchtower",
                        help="Stream live cell events (run under the Monitor tool).")
    wt.add_argument("cell", help="Cell slug.")
    wt.add_argument("--idle", type=int, default=30, metavar="MIN",
                    help="Initial silence (minutes) before the first `idle` "
                         "heartbeat (default 30; 0 disables). Each subsequent "
                         "silent interval doubles, capped at 24h, and resets to "
                         "this initial value on any activity.")
    wt.add_argument("--quiet", action="append", default=[], choices=["filesystem"],
                    metavar="EVENT",
                    help="Repeatable. Handle but don't emit this event type (the "
                         "file still auto-downloads; only the notification is "
                         "suppressed). A coordination hub passes `--quiet filesystem` "
                         "to drop redundant publish pings when a pointer dispatch "
                         "already announced the file.")
    wt.add_argument("--alias-trigger", metavar="PREFIX", default=None,
                    help="Opt-in aliases: when a message body starts with this "
                         "prefix, the first shell-safe token after it is the "
                         "sender's alias. Off (ids only) when omitted; the `team` "
                         "skill sets it.")
    wt.set_defaults(func=cmd_watchtower)

    al = sub.add_parser("aliases", help="List this cell's local alias map.")
    al.add_argument("cell", help="Cell slug.")
    al.set_defaults(func=cmd_aliases)

    ali = sub.add_parser("alias",
                         help="Show or set an alias (local): one arg shows (name "
                              "or id), two args set (order-free).")
    ali.add_argument("cell", help="Cell slug.")
    ali.add_argument("args", nargs="+", metavar="NAME|ID",
                     help="<name-or-id> to show, or <name> <id> (either order) to set.")
    ali.set_defaults(func=cmd_alias)

    un = sub.add_parser("unalias", help="Clear an alias (local).")
    un.add_argument("cell", help="Cell slug.")
    un.add_argument("name", help="Alias to remove.")
    un.set_defaults(func=cmd_unalias)

    wk = sub.add_parser("wake",
                        help="SIGUSR1 the local watchtower for this cell so it "
                             "polls immediately and resets the cadence ladder.")
    wk.add_argument("cell", help="Cell slug.")
    wk.set_defaults(func=cmd_wake)

    stp = sub.add_parser("stop",
                         help="Ask my own watchtower for this cell to exit "
                              "cleanly, via its inbox. Never touches a peer's.")
    stp.add_argument("cell", help="Cell slug.")
    stp.set_defaults(func=cmd_stop)

    sts = sub.add_parser("status",
                         help="Report whether my watchtower for this cell is "
                              "alive - and when it is not, why it stopped.")
    sts.add_argument("cell", help="Cell slug.")
    sts.set_defaults(func=cmd_status)

    rd = sub.add_parser("read", help="Print cell message history.")
    rd.add_argument("cell", help="Cell slug.")
    rd.add_argument("--from", dest="from_", metavar="COMRADE",
                    help="Only this sender's messages (default: all comrades).")
    rd.add_argument("--to", metavar="COMRADE",
                    help="Only messages a given comrade would receive (incl. broadcasts).")
    g = rd.add_mutually_exclusive_group()
    g.add_argument("--ts", help="Print only the message with this exact timestamp.")
    g.add_argument("--last", type=int, metavar="N",
                   help="Print only the last N messages.")
    rd.add_argument("--full", action="store_true",
                    help="With --ts: print the whole body. Default prints only the "
                         "continuation past the watchtower preview cutoff (the "
                         "prefix you already saw). Use when you never saw the "
                         "preview - a successor or post-compaction read.")
    rd.set_defaults(func=cmd_read)

    rm = sub.add_parser("rm",
                        help="Delete a cell and all its blobs (user-directed).")
    rm.add_argument("cell", help="Cell slug.")
    rm.add_argument("--yes", action="store_true",
                    help="Actually delete; without it, this is a dry run.")
    rm.set_defaults(func=cmd_rm)

    pub = sub.add_parser("publish", help="Share a file with a cell.")
    pub.add_argument("cell", help="Cell slug.")
    pub.add_argument("--to", action="append", default=[], metavar="COMRADE",
                     help="Repeatable. Comrade id; omit for broadcast.")
    pub.add_argument("path", help="Path of the file to publish.")
    pub.set_defaults(func=cmd_publish)

    unp = sub.add_parser("unpublish",
                         help="Withdraw a previously-published file.")
    unp.add_argument("cell", help="Cell slug.")
    unp.add_argument("--to", action="append", default=[], metavar="COMRADE",
                     help="Repeatable. Comrade id; omit for broadcast.")
    unp.add_argument("path", help="Path of the file to withdraw (as published).")
    unp.set_defaults(func=cmd_unpublish)

    pl = sub.add_parser("pull",
                        help="Download published files matching path expressions "
                             "into the local mirror (silent + exit 0 on success).")
    pl.add_argument("cell", help="Cell slug.")
    pl.add_argument("expr", nargs="+", metavar="PATH",
                    help="File or directory path(s), as originally published.")
    pl.set_defaults(func=cmd_pull)

    return p


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)
    # Strip the watchtower's ps-title tag - the trailing `-- <comrade-id>` its
    # re-exec appends (see cmd_watchtower) - before parsing: the tag is for
    # `ps`, not argparse, whose own `--` handling leaks through subparsers.
    if argv[:1] == ["watchtower"] and argv[-2:-1] == ["--"]:
        argv = argv[:-2]
    parser = build_parser()
    # `dispatch` has an optional positional (body) that normally FOLLOWS optionals
    # - `dispatch cell --to X "msg"`. argparse cannot express that: with nargs="?"
    # it matches body against zero args at the first positional run (before --to
    # is even seen), then reports the real message as "unrecognized". It does so
    # deterministically, leaving the body as the sole extra, so recover it here.
    # Deliberately narrow - one extra, on dispatch, only when body came back empty,
    # and never something that looks like a flag (but `-` IS a body: read stdin).
    args, extras = parser.parse_known_args(argv)
    if (extras and len(extras) == 1
            and getattr(args, "func", None) is cmd_dispatch
            and getattr(args, "body", None) is None
            and (extras[0] == "-" or not extras[0].startswith("-"))):
        args.body, extras = extras[0], []
    if extras:
        parser.error(f"unrecognized arguments: {' '.join(extras)}")
    args.func(args)


if __name__ == "__main__":
    main()
