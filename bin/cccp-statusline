#!/bin/bash
#
# Collect session status data for CCCP.
#
# Reads the statusLine JSON payload from stdin and atomically writes it to
# <data_dir>/<session_id>.json for use by other programs in this plugin.
# 
# Produces no output
#
# --plugin-data <dir>   Data directory (required).
# --passthrough         Copy stdin to stdout, for piping into another
#                       statusLine command.

data_dir=""
passthrough=false
include_auth=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --plugin-data) data_dir="$2"; shift 2 ;;
        --plugin-data=*) data_dir="${1#--plugin-data=}"; shift ;;
        --passthrough) passthrough=true; shift ;;
        --include-auth) include_auth=true; shift ;;
        *) shift ;;
    esac
done

if [[ -z "$data_dir" ]]; then
    echo "cccp-statusline: --plugin-data is required" >&2
    exit 1
fi

input=$(cat)

# Harvested Claude Code session telemetry lives under
# telemetry/<v-major|inline>/claude-code/ in the plugin data tree (see the map
# in bin/cccp). --plugin-data is still the tree root.
#
# One data root holds every version installed from one marketplace (the root is
# keyed by marketplace, not version), so the tree is partitioned by the WRITING
# plugin's major version - v3, v4 - and two releases can never scribble on each
# other's snapshots. A checkout writes to "inline" instead: its plugin.json
# version is whatever the branch happens to say, which is not a release.
#
# claude-tokens reads this same directory and derives the segment from the same
# file by the same rule (major digits before the first dot, .git means inline).
# The two rules must stay identical: a divergence silently strands the reader,
# which is exactly the failure jhs/cccp#14 was.
root=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
if [[ -d "$root/.git" ]]; then
    version_segment="inline"
else
    major=$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([0-9][0-9]*\)\..*/\1/p' \
        "$root/.claude-plugin/plugin.json" 2>/dev/null | head -1)
    if [[ -n "$major" ]]; then
        version_segment="v$major"
    else
        version_segment="unknown"
    fi
fi
tele_dir="$data_dir/telemetry/$version_segment/claude-code"

# Write claude auth status. Cached with 5h TTL.
auth_file="$tele_dir/auth-status.json"
if ! [[ -f "$auth_file" ]] || [[ -z $(find "$auth_file" -mmin -300 -print 2>/dev/null) ]]; then
    mkdir -p "$tele_dir" 2>/dev/null
    auth_tmp=$(mktemp "${auth_file}.XXXXXX")
    if claude auth status 2>/dev/null >"$auth_tmp"; then
        mv "$auth_tmp" "$auth_file" 2>/dev/null || rm -f "$auth_tmp" 2>/dev/null
    else
        rm -f "$auth_tmp"
    fi
fi

# Write session status data to a per-session file for claude-tokens.
sid=$(printf '%s' "$input" | jq -r '.session_id // empty')
if [[ -n "$sid" ]]; then
    mkdir -p "$tele_dir" 2>/dev/null
    printf '%s' "$input" > "$tele_dir/$sid.json.tmp" && mv "$tele_dir/$sid.json.tmp" "$tele_dir/$sid.json"
fi

if $passthrough; then
    if $include_auth && [[ -f "$auth_file" ]]; then
        printf '%s' "$input" | jq --slurpfile auth "$auth_file" '. + {__auth: $auth[0]}'
    else
        printf '%s' "$input"
    fi
fi
